<Project>

  <!--
    SourceBuild.targets - Replaces NuGet PackageReferences with ProjectReferences
    to local Avalonia and/or MAUI source checkouts for source-level debugging.

    Activated by setting AvaloniaSourcePath and/or MauiSourcePath properties
    (typically via Directory.Build.props.user).
  -->

  <!--
    When building from source, the NuGet Avalonia package's build infrastructure
    (props/targets) is not available. Import the equivalent files from the source tree:
      - AvaloniaBuildTasks.props: globs *.axaml into the AvaloniaXaml item group
      - Avalonia.Generators.props: configures the XAML source generator (InitializeComponent)
      - AvaloniaBuildTasks.targets: XAML compilation and resource embedding tasks
    We also set AvaloniaBuildTasksLocation to the source-built Build.Tasks assembly.
  -->
  <PropertyGroup Condition="'$(AvaloniaSourcePath)' != ''">
    <AvaloniaBuildTasksLocation>$(AvaloniaSourcePath)/src/Avalonia.Build.Tasks/bin/Debug/netstandard2.0/Avalonia.Build.Tasks.dll</AvaloniaBuildTasksLocation>
    <EnableAvaloniaXamlCompilation Condition="'$(EnableAvaloniaXamlCompilation)' == ''">true</EnableAvaloniaXamlCompilation>
    <AvaloniaUseCompiledBindingsByDefault Condition="'$(AvaloniaUseCompiledBindingsByDefault)' == ''">true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <Import Project="$(AvaloniaSourcePath)/packages/Avalonia/AvaloniaBuildTasks.props"
          Condition="'$(AvaloniaSourcePath)' != ''" />
  <Import Project="$(AvaloniaSourcePath)/src/tools/Avalonia.Generators/Avalonia.Generators.props"
          Condition="'$(AvaloniaSourcePath)' != ''" />
  <Import Project="$(AvaloniaSourcePath)/packages/Avalonia/AvaloniaBuildTasks.targets"
          Condition="'$(AvaloniaSourcePath)' != ''" />

  <Target Name="_ReplaceAvaloniaSourceReferences"
          BeforeTargets="CollectPackageReferences;ResolvePackageAssets"
          Condition="'$(AvaloniaSourcePath)' != ''">
    <ItemGroup>
      <!--
        The Avalonia NuGet metapackage bundles Avalonia.Base, Avalonia.Controls, etc.
        as ref assemblies. When building from source, the metapackage csproj is just an
        empty shell whose transitive ProjectReferences don't flow. Reference the core
        libraries directly instead.
      -->
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Base/Avalonia.Base.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Controls/Avalonia.Controls.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Dialogs/Avalonia.Dialogs.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Markup/Avalonia.Markup/Avalonia.Markup.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Markup/Avalonia.Markup.Xaml/Avalonia.Markup.Xaml.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.OpenGL/Avalonia.OpenGL.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Metal/Avalonia.Metal.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Vulkan/Avalonia.Vulkan.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.MicroCom/Avalonia.MicroCom.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.DesignerSupport/Avalonia.DesignerSupport.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Remote.Protocol/Avalonia.Remote.Protocol.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/tools/Avalonia.Generators/Avalonia.Generators.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))"
                        ReferenceOutputAssembly="false"
                        PrivateAssets="all"
                        OutputItemType="Analyzer" />
      <!--
        MicroCom.Runtime is a NuGet dependency of Avalonia.MicroCom. It doesn't flow
        transitively across repo boundaries, so add it explicitly.
      -->
      <PackageReference Include="MicroCom.Runtime"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))"
                        Version="$(MicroComVersion)" />
      <PackageReference Remove="Avalonia" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Themes.Fluent/Avalonia.Themes.Fluent.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Themes.Fluent'))" />
      <PackageReference Remove="Avalonia.Themes.Fluent" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Fonts.Inter/Avalonia.Fonts.Inter.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Fonts.Inter'))" />
      <PackageReference Remove="Avalonia.Fonts.Inter" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Desktop/Avalonia.Desktop.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Desktop'))" />
      <!--
        HarfBuzzSharp is a NuGet dependency of Avalonia.HarfBuzz, which is pulled in
        by Avalonia.Desktop. It doesn't flow transitively across repo boundaries.
      -->
      <PackageReference Include="HarfBuzzSharp"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Desktop'))
                                OR @(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.HarfBuzz'))"
                        Version="$(HarfBuzzSharpVersion)" />
      <PackageReference Remove="Avalonia.Desktop" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Skia/Avalonia.Skia/Avalonia.Skia.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Skia'))" />
      <PackageReference Include="SkiaSharp"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Skia'))"
                        Version="$(SkiaSharpVersion)" />
      <PackageReference Remove="Avalonia.Skia" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/iOS/Avalonia.iOS/Avalonia.iOS.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.iOS'))" />
      <PackageReference Remove="Avalonia.iOS" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Android/Avalonia.Android/Avalonia.Android.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Android'))" />
      <PackageReference Remove="Avalonia.Android" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Browser/Avalonia.Browser/Avalonia.Browser.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Browser'))" />
      <PackageReference Remove="Avalonia.Browser" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Headless/Avalonia.Headless/Avalonia.Headless.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Headless'))" />
      <PackageReference Remove="Avalonia.Headless" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Headless/Avalonia.Headless.XUnit/Avalonia.Headless.XUnit.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Headless.XUnit'))" />
      <PackageReference Remove="Avalonia.Headless.XUnit" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/HarfBuzz/Avalonia.HarfBuzz/Avalonia.HarfBuzz.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.HarfBuzz'))" />
      <PackageReference Remove="Avalonia.HarfBuzz" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Themes.Simple/Avalonia.Themes.Simple.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Themes.Simple'))" />
      <PackageReference Remove="Avalonia.Themes.Simple" />
    </ItemGroup>
  </Target>

  <Target Name="_ReplaceMauiSourceReferences"
          BeforeTargets="CollectPackageReferences;ResolvePackageAssets"
          Condition="'$(MauiSourcePath)' != ''">
    <!--
      Determine whether any MAUI packages are being replaced so we can add
      the Microsoft.Extensions packages exactly once (avoiding NU1504 duplicates).
    -->
    <PropertyGroup>
      <_NeedsMauiExtensions Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Core'))
                                    OR @(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls'))
                                    OR @(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Core'))
                                    OR @(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))">true</_NeedsMauiExtensions>
    </PropertyGroup>
    <ItemGroup>
      <!--
        The Microsoft.Maui.Controls.Core NuGet package transitively pulls in
        Microsoft.Maui.Core, Microsoft.Maui.Graphics, and Microsoft.Maui.Essentials.
        When building from source, transitive ProjectReferences across repo boundaries
        don't flow reliably. Reference the core libraries directly instead.
      -->
      <ProjectReference Include="$(MauiSourcePath)/src/Controls/src/Core/Controls.Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Core'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Controls/src/Xaml/Controls.Xaml.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Core'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Core/src/Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Core'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Graphics/src/Graphics/Graphics.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Core'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Essentials/src/Essentials.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Core'))" />
      <PackageReference Remove="Microsoft.Maui.Controls.Core" />

      <!--
        The Microsoft.Maui.Controls NuGet metapackage wraps Microsoft.Maui.Controls.Core,
        Microsoft.Maui.Controls.Xaml, XAML source generators and build infrastructure.
        When building from source, replace it with the same set of direct ProjectReferences.
      -->
      <ProjectReference Include="$(MauiSourcePath)/src/Controls/src/Core/Controls.Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Controls/src/Xaml/Controls.Xaml.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Core/src/Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Graphics/src/Graphics/Graphics.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Essentials/src/Essentials.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls'))" />
      <PackageReference Remove="Microsoft.Maui.Controls" />

      <ProjectReference Include="$(MauiSourcePath)/src/Core/src/Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Core'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Essentials/src/Essentials.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Core'))" />
      <PackageReference Remove="Microsoft.Maui.Core" />

      <ProjectReference Include="$(MauiSourcePath)/src/Graphics/src/Graphics/Graphics.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Graphics'))" />
      <PackageReference Remove="Microsoft.Maui.Graphics" />

      <ProjectReference Include="$(MauiSourcePath)/src/Graphics/src/Graphics.Skia/Graphics.Skia.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Graphics.Skia'))" />
      <PackageReference Remove="Microsoft.Maui.Graphics.Skia" />

      <ProjectReference Include="$(MauiSourcePath)/src/Controls/Maps/src/Controls.Maps.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Core/maps/src/Maps.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Controls/src/Core/Controls.Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Core/src/Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Graphics/src/Graphics/Graphics.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))" />
      <ProjectReference Include="$(MauiSourcePath)/src/Essentials/src/Essentials.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))" />
      <PackageReference Remove="Microsoft.Maui.Controls.Maps" />

      <!--
        The MAUI NuGet packages transitively bring in Microsoft.Extensions packages.
        These NuGet-to-NuGet transitive dependencies don't flow when replaced with
        ProjectReferences, so add them explicitly. Added once using a flag to avoid
        NU1504 duplicate PackageReference errors when multiple MAUI packages are present.
      -->
      <PackageReference Include="Microsoft.Extensions.DependencyInjection"
                        Condition="'$(_NeedsMauiExtensions)' == 'true'"
                        Version="$(MicrosoftExtensionsVersion)" />
      <PackageReference Include="Microsoft.Extensions.Logging"
                        Condition="'$(_NeedsMauiExtensions)' == 'true'"
                        Version="$(MicrosoftExtensionsVersion)" />
      <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"
                        Condition="'$(_NeedsMauiExtensions)' == 'true'"
                        Version="$(MicrosoftExtensionsVersion)" />
      <PackageReference Include="Microsoft.Extensions.Configuration"
                        Condition="'$(_NeedsMauiExtensions)' == 'true'"
                        Version="$(MicrosoftExtensionsVersion)" />
      <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"
                        Condition="'$(_NeedsMauiExtensions)' == 'true'"
                        Version="$(MicrosoftExtensionsVersion)" />
    </ItemGroup>
  </Target>

  <!--
    When building MAUI from source, replace IgnoresAccessChecksToGenerator with
    InternalsVisibleTo attributes injected directly into the MAUI source tree.
    The generated .cs files are picked up by each project's default Compile glob.
    Essentials uses the *.shared.cs naming convention since it disables default
    compile items and only includes **/*.shared.cs explicitly.
  -->
  <PropertyGroup Condition="'$(MauiSourcePath)' != ''">
    <DefineConstants>$(DefineConstants);MAUI_SOURCE_BUILD</DefineConstants>
    <_MauiCoreIVTFile>$(MauiSourcePath)/src/Core/src/Properties/InternalsVisibleTo.Avalonia.g.cs</_MauiCoreIVTFile>
    <_MauiControlsIVTFile>$(MauiSourcePath)/src/Controls/src/Core/Properties/InternalsVisibleTo.Avalonia.g.cs</_MauiControlsIVTFile>
    <_MauiEssentialsIVTFile>$(MauiSourcePath)/src/Essentials/src/Properties/InternalsVisibleTo.Avalonia.shared.cs</_MauiEssentialsIVTFile>
  </PropertyGroup>

  <Target Name="_WriteMauiInternalsVisibleTo"
          BeforeTargets="CollectPackageReferences"
          Condition="'$(MauiSourcePath)' != '' AND '$(AddMauiInternals)' == 'true'">
    <ItemGroup>
      <_AvaloniaIVTLines Include="// Auto-generated by Avalonia.Controls.Maui source build. Do not check in." />
      <_AvaloniaIVTLines Include="[assembly: System.Runtime.CompilerServices.InternalsVisibleTo(&quot;Avalonia.Controls.Maui&quot;)]" />
      <_AvaloniaIVTLines Include="[assembly: System.Runtime.CompilerServices.InternalsVisibleTo(&quot;Avalonia.Controls.Maui.Compatibility&quot;)]" />
      <_AvaloniaIVTLines Include="[assembly: System.Runtime.CompilerServices.InternalsVisibleTo(&quot;Avalonia.Controls.Maui.Graphics&quot;)]" />
      <_AvaloniaIVTLines Include="[assembly: System.Runtime.CompilerServices.InternalsVisibleTo(&quot;Avalonia.Controls.Maui.Essentials&quot;)]" />
      <_AvaloniaIVTLines Include="[assembly: System.Runtime.CompilerServices.InternalsVisibleTo(&quot;Avalonia.Controls.Maui.Maps.Mapsui&quot;)]" />
    </ItemGroup>
    <WriteLinesToFile File="$(_MauiCoreIVTFile)"
                     Lines="@(_AvaloniaIVTLines)"
                     Overwrite="true" />
    <WriteLinesToFile File="$(_MauiControlsIVTFile)"
                     Lines="@(_AvaloniaIVTLines)"
                     Overwrite="true" />
    <WriteLinesToFile File="$(_MauiEssentialsIVTFile)"
                     Lines="@(_AvaloniaIVTLines)"
                     Overwrite="true" />
  </Target>

  <Target Name="_CleanMauiInternalsVisibleTo"
          AfterTargets="Clean"
          Condition="'$(MauiSourcePath)' != ''">
    <Delete Files="$(_MauiCoreIVTFile)" Condition="Exists('$(_MauiCoreIVTFile)')" />
    <Delete Files="$(_MauiControlsIVTFile)" Condition="Exists('$(_MauiControlsIVTFile)')" />
    <Delete Files="$(_MauiEssentialsIVTFile)" Condition="Exists('$(_MauiEssentialsIVTFile)')" />
  </Target>

  <!--
    When building from MAUI source with UseMaui=true, the Microsoft.Maui.Controls
    NuGet package's build infrastructure (global usings, XAML source generators,
    XAML compilation targets) is not available because we replaced the PackageReference
    with ProjectReferences. Import the equivalent build infrastructure from the MAUI
    source tree's .buildtasks/ directory, which contains the same props/targets files
    that are packed into the NuGet package.

    The .buildtasks/ directory is generated by the MAUI build and must exist before
    building Avalonia.Controls.Maui from source. It contains pre-built DLLs for the
    XAML source generator (Microsoft.Maui.Controls.SourceGen.dll) and XamlC build
    task (Microsoft.Maui.Controls.Build.Tasks.dll).

    Import order:
      1. Set EnableDefaultMauiItems properties (normally set in After.targets)
      2. Import Globs.props: global usings + MauiXaml/MauiCss item definitions
      3. Import Build.Tasks.targets: registers XamlC task, adds source generators,
         imports Before.targets, and schedules After.targets via AfterMicrosoftNETSdkTargets
  -->
  <PropertyGroup Condition="'$(MauiSourcePath)' != '' AND '$(UseMaui)' == 'true'">
    <EnableDefaultMauiItems Condition="'$(EnableDefaultMauiItems)' == ''">$(EnableDefaultItems)</EnableDefaultMauiItems>
    <EnableDefaultXamlItems Condition="'$(EnableDefaultXamlItems)' == ''">$(EnableDefaultMauiItems)</EnableDefaultXamlItems>
    <EnableDefaultCssItems Condition="'$(EnableDefaultCssItems)' == ''">$(EnableDefaultMauiItems)</EnableDefaultCssItems>
    <EnableDefaultEmbeddedResourceItems Condition="'$(EnableDefaultEmbeddedResourceItems)' == ''">$(EnableDefaultMauiItems)</EnableDefaultEmbeddedResourceItems>
  </PropertyGroup>

  <Import Project="$(MauiSourcePath)/.buildtasks/Microsoft.Maui.Controls.Globs.props"
          Condition="'$(MauiSourcePath)' != '' AND '$(UseMaui)' == 'true'" />

  <Import Project="$(MauiSourcePath)/.buildtasks/Microsoft.Maui.Controls.Build.Tasks.targets"
          Condition="'$(MauiSourcePath)' != '' AND '$(UseMaui)' == 'true'" />

  <!--
    The Microsoft.Maui.Resizetizer NuGet package provides image/font/asset
    processing targets (ResizetizeImages, ProcessMauiFonts, etc.).
    When building from source with UseMaui=true, import these from the MAUI
    source tree instead.
  -->
  <Import Project="$(MauiSourcePath)/.buildtasks/Microsoft.Maui.Resizetizer.targets"
          Condition="'$(MauiSourcePath)' != '' AND '$(UseMaui)' == 'true'" />

</Project>
