<Project>

  <!--
    SourceBuild.targets - Replaces NuGet PackageReferences with ProjectReferences
    to local Avalonia and/or MAUI source checkouts for source-level debugging.

    Activated by setting AvaloniaSourcePath and/or MauiSourcePath properties
    (typically via Directory.Build.props.user).
  -->

  <!--
    When building from source, the NuGet Avalonia package's build infrastructure
    (props/targets) is not available. Import the equivalent files from the source tree:
      - AvaloniaBuildTasks.props: globs *.axaml into the AvaloniaXaml item group
      - Avalonia.Generators.props: configures the XAML source generator (InitializeComponent)
      - AvaloniaBuildTasks.targets: XAML compilation and resource embedding tasks
    We also set AvaloniaBuildTasksLocation to the source-built Build.Tasks assembly.
  -->
  <PropertyGroup Condition="'$(AvaloniaSourcePath)' != ''">
    <AvaloniaBuildTasksLocation>$(AvaloniaSourcePath)/src/Avalonia.Build.Tasks/bin/Debug/netstandard2.0/Avalonia.Build.Tasks.dll</AvaloniaBuildTasksLocation>
    <EnableAvaloniaXamlCompilation Condition="'$(EnableAvaloniaXamlCompilation)' == ''">true</EnableAvaloniaXamlCompilation>
    <AvaloniaUseCompiledBindingsByDefault Condition="'$(AvaloniaUseCompiledBindingsByDefault)' == ''">true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <Import Project="$(AvaloniaSourcePath)/packages/Avalonia/AvaloniaBuildTasks.props"
          Condition="'$(AvaloniaSourcePath)' != ''" />
  <Import Project="$(AvaloniaSourcePath)/src/tools/Avalonia.Generators/Avalonia.Generators.props"
          Condition="'$(AvaloniaSourcePath)' != ''" />
  <Import Project="$(AvaloniaSourcePath)/packages/Avalonia/AvaloniaBuildTasks.targets"
          Condition="'$(AvaloniaSourcePath)' != ''" />

  <Target Name="_ReplaceAvaloniaSourceReferences"
          BeforeTargets="CollectPackageReferences;ResolvePackageAssets"
          Condition="'$(AvaloniaSourcePath)' != ''">
    <ItemGroup>
      <!--
        The Avalonia NuGet metapackage bundles Avalonia.Base, Avalonia.Controls, etc.
        as ref assemblies. When building from source, the metapackage csproj is just an
        empty shell whose transitive ProjectReferences don't flow. Reference the core
        libraries directly instead.
      -->
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Base/Avalonia.Base.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Controls/Avalonia.Controls.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Dialogs/Avalonia.Dialogs.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Markup/Avalonia.Markup/Avalonia.Markup.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Markup/Avalonia.Markup.Xaml/Avalonia.Markup.Xaml.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.OpenGL/Avalonia.OpenGL.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Metal/Avalonia.Metal.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Vulkan/Avalonia.Vulkan.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.MicroCom/Avalonia.MicroCom.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.DesignerSupport/Avalonia.DesignerSupport.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Remote.Protocol/Avalonia.Remote.Protocol.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))" />
      <ProjectReference Include="$(AvaloniaSourcePath)/src/tools/Avalonia.Generators/Avalonia.Generators.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia'))"
                        ReferenceOutputAssembly="false"
                        PrivateAssets="all"
                        OutputItemType="Analyzer" />
      <PackageReference Remove="Avalonia" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Themes.Fluent/Avalonia.Themes.Fluent.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Themes.Fluent'))" />
      <PackageReference Remove="Avalonia.Themes.Fluent" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Fonts.Inter/Avalonia.Fonts.Inter.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Fonts.Inter'))" />
      <PackageReference Remove="Avalonia.Fonts.Inter" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Desktop/Avalonia.Desktop.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Desktop'))" />
      <PackageReference Remove="Avalonia.Desktop" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Skia/Avalonia.Skia/Avalonia.Skia.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Skia'))" />
      <PackageReference Remove="Avalonia.Skia" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/iOS/Avalonia.iOS/Avalonia.iOS.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.iOS'))" />
      <PackageReference Remove="Avalonia.iOS" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Android/Avalonia.Android/Avalonia.Android.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Android'))" />
      <PackageReference Remove="Avalonia.Android" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Browser/Avalonia.Browser/Avalonia.Browser.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Browser'))" />
      <PackageReference Remove="Avalonia.Browser" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Headless/Avalonia.Headless/Avalonia.Headless.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Headless'))" />
      <PackageReference Remove="Avalonia.Headless" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Headless/Avalonia.Headless.XUnit/Avalonia.Headless.XUnit.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Headless.XUnit'))" />
      <PackageReference Remove="Avalonia.Headless.XUnit" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/HarfBuzz/Avalonia.HarfBuzz/Avalonia.HarfBuzz.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.HarfBuzz'))" />
      <PackageReference Remove="Avalonia.HarfBuzz" />

      <ProjectReference Include="$(AvaloniaSourcePath)/src/Avalonia.Themes.Simple/Avalonia.Themes.Simple.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Avalonia.Themes.Simple'))" />
      <PackageReference Remove="Avalonia.Themes.Simple" />
    </ItemGroup>
  </Target>

  <Target Name="_ReplaceMauiSourceReferences"
          BeforeTargets="CollectPackageReferences;ResolvePackageAssets"
          Condition="'$(MauiSourcePath)' != ''">
    <ItemGroup>
      <ProjectReference Include="$(MauiSourcePath)/src/Controls/src/Core/Controls.Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Core'))" />
      <PackageReference Remove="Microsoft.Maui.Controls.Core" />

      <ProjectReference Include="$(MauiSourcePath)/src/Core/src/Core.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Core'))" />
      <PackageReference Remove="Microsoft.Maui.Core" />

      <ProjectReference Include="$(MauiSourcePath)/src/Graphics/src/Graphics/Graphics.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Graphics'))" />
      <PackageReference Remove="Microsoft.Maui.Graphics" />

      <ProjectReference Include="$(MauiSourcePath)/src/Graphics/src/Graphics.Skia/Graphics.Skia.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Graphics.Skia'))" />
      <PackageReference Remove="Microsoft.Maui.Graphics.Skia" />

      <ProjectReference Include="$(MauiSourcePath)/src/Controls/Maps/src/Controls.Maps.csproj"
                        Condition="@(PackageReference->AnyHaveMetadataValue('Identity', 'Microsoft.Maui.Controls.Maps'))" />
      <PackageReference Remove="Microsoft.Maui.Controls.Maps" />
    </ItemGroup>
  </Target>

</Project>
