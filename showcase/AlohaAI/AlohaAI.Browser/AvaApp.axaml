<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AlohaAI.Browser.AvaloniaApp"
             Name="AlohaAI"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="TabBarBackground">#18132A</Color>
                    <Color x:Key="TabItemForeground">#80FFFFFF</Color>
                    <Color x:Key="TabItemSelectedForeground">#FFFFFF</Color>
                    <Color x:Key="TabItemHoverForeground">#C0FFFFFF</Color>
                    <Color x:Key="TabItemSelectedBg">#405B8FD4</Color>
                    <Color x:Key="TabItemHoverBg">#205B8FD4</Color>
                    <Color x:Key="TabItemSelectedHoverBg">#505B8FD4</Color>
                    <Color x:Key="TabItemPressedBg">#305B8FD4</Color>
                    <Color x:Key="TabItemSelectedPressedBg">#605B8FD4</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="TabBarBackground">#F0EEF5</Color>
                    <Color x:Key="TabItemForeground">#80000000</Color>
                    <Color x:Key="TabItemSelectedForeground">#000000</Color>
                    <Color x:Key="TabItemHoverForeground">#C0000000</Color>
                    <Color x:Key="TabItemSelectedBg">#405B8FD4</Color>
                    <Color x:Key="TabItemHoverBg">#205B8FD4</Color>
                    <Color x:Key="TabItemSelectedHoverBg">#505B8FD4</Color>
                    <Color x:Key="TabItemPressedBg">#305B8FD4</Color>
                    <Color x:Key="TabItemSelectedPressedBg">#605B8FD4</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Pill-style tab bar for Shell TabBar -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="{DynamicResource TabBarBackground}" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="4,4" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Foreground" Value="{DynamicResource TabItemForeground}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="5,0,5,10" />
        </Style>

        <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedForeground}" />
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedBg}" />
        </Style>

        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabItemHoverBg}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TabItemHoverForeground}" />
        </Style>
        <Style Selector="TabItem:selected:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedHoverBg}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TabItemSelectedForeground}" />
        </Style>

        <Style Selector="TabItem:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabItemPressedBg}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TabItemHoverForeground}" />
        </Style>
        <Style Selector="TabItem:selected:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedPressedBg}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TabItemSelectedForeground}" />
        </Style>

        <Style Selector="TabItem Image.shell-tab-header-icon">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
        </Style>
    </Application.Styles>
</Application>
