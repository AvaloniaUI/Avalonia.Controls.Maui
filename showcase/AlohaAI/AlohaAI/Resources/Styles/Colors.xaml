<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- AlohaAI Brand Colors — Tropical Sunset Palette -->
    <Color x:Key="Primary">#5B8FD4</Color>
    <Color x:Key="PrimaryDark">#7BA3DB</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#7B68AE</Color>
    <Color x:Key="SecondaryDarkText">#FFFFFF</Color>
    <Color x:Key="Tertiary">#E88BBF</Color>
    <Color x:Key="Accent">#F5A623</Color>

    <!-- Gradient Anchors (for reference in code) -->
    <Color x:Key="GradientTop">#5B9FE6</Color>
    <Color x:Key="GradientMid">#7B68AE</Color>
    <Color x:Key="GradientBottom">#2D1B69</Color>

    <!-- Learning Path Colors -->
    <Color x:Key="AgenticAIColor">#5B8FD4</Color>
    <Color x:Key="MLFundamentalsColor">#7B68AE</Color>
    <Color x:Key="PracticeAIColor">#E88BBF</Color>

    <!-- Streak / Gamification -->
    <Color x:Key="StreakColor">#F5A623</Color>
    <Color x:Key="XPColor">#7EB4F0</Color>
    <Color x:Key="SuccessColor">#66BB6A</Color>
    <Color x:Key="ErrorColor">#EF5350</Color>

    <!-- Neutrals -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <Color x:Key="Gray50">#F5F3F7</Color>
    <Color x:Key="Gray100">#EBE7EF</Color>
    <Color x:Key="Gray200">#D6D0DC</Color>
    <Color x:Key="Gray300">#B8B0C2</Color>
    <Color x:Key="Gray400">#9A90A8</Color>
    <Color x:Key="Gray500">#6E6580</Color>
    <Color x:Key="Gray600">#4A4258</Color>
    <Color x:Key="Gray700">#342D42</Color>
    <Color x:Key="Gray800">#231E30</Color>
    <Color x:Key="Gray900">#18132A</Color>
    <Color x:Key="Gray950">#080510</Color>

    <!-- Surface Colors -->
    <Color x:Key="SurfaceDark">#18132A</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="CardDark">#231E30</Color>
    <Color x:Key="CardLight">#F5F3F7</Color>
    <Color x:Key="CodeBlockDark">#080510</Color>
    <Color x:Key="CodeBlockLight">#F0EDF4</Color>

    <!-- Glassmorphism & Ambient -->
    <Color x:Key="GlassSurface">#E81A1035</Color> <!-- Semi-transparent dark -->
    <Color x:Key="GlassBorder">#33FFFFFF</Color>   <!-- Subtle highlight -->
    <Color x:Key="AmbientBlue">#5B9FE6</Color>
    <Color x:Key="AmbientPurple">#7B68AE</Color>
    <Color x:Key="AmbientPink">#E88BBF</Color>

    <!-- Theme-Aware Semantic Colors (Dark / Light) -->
    <Color x:Key="PageBg_Dark">#120C24</Color>
    <Color x:Key="PageBg_Light">#F5F3F7</Color>
    <Color x:Key="GradientTop_Dark">#1E1035</Color>
    <Color x:Key="GradientTop_Light">#E8E0F2</Color>
    <Color x:Key="GradientOverlayMid_Dark">#901E1035</Color>
    <Color x:Key="GradientOverlayMid_Light">#C0E8E0F2</Color>
    <Color x:Key="GradientOverlayEnd_Dark">#FF120C24</Color>
    <Color x:Key="GradientOverlayEnd_Light">#FFF5F3F7</Color>
    <Color x:Key="CardBg_Dark">#151025</Color>
    <Color x:Key="CardBg_Light">#FFFFFF</Color>
    <Color x:Key="CardBgAlt_Dark">#1A1035</Color>
    <Color x:Key="CardBgAlt_Light">#F0ECF5</Color>
    <Color x:Key="CardBgStats_Dark">#181530</Color>
    <Color x:Key="CardBgStats_Light">#F0ECF5</Color>
    <Color x:Key="GlassSurfaceDark_Dark">#151025</Color>
    <Color x:Key="GlassSurfaceDark_Light">#FFFFFF</Color>
    <Color x:Key="TextPrimary_Dark">#FFFFFF</Color>
    <Color x:Key="TextPrimary_Light">#18132A</Color>
    <Color x:Key="TextSecondary_Dark">#AAAAAA</Color>
    <Color x:Key="TextSecondary_Light">#6E6580</Color>
    <Color x:Key="TextTertiary_Dark">#888888</Color>
    <Color x:Key="TextTertiary_Light">#9A90A8</Color>
    <Color x:Key="TextSubtle_Dark">#CCCCCC</Color>
    <Color x:Key="TextSubtle_Light">#4A4258</Color>
    <Color x:Key="DividerColor_Dark">#20FFFFFF</Color>
    <Color x:Key="DividerColor_Light">#20000000</Color>
    <Color x:Key="InputBg_Dark">#15FFFFFF</Color>
    <Color x:Key="InputBg_Light">#10000000</Color>
    <Color x:Key="InputBorder_Dark">#30FFFFFF</Color>
    <Color x:Key="InputBorder_Light">#30000000</Color>
    <Color x:Key="OverlayBg_Dark">#80000000</Color>
    <Color x:Key="OverlayBg_Light">#40000000</Color>
    <Color x:Key="ModalBackdrop_Dark">#FF0D0B1E</Color>
    <Color x:Key="ModalBackdrop_Light">#80000000</Color>
    <Color x:Key="ModalCardBg_Dark">#FF1A1035</Color>
    <Color x:Key="ModalCardBg_Light">#FFFFFFFF</Color>
    <Color x:Key="ProgressBarBg_Dark">#12FFFFFF</Color>
    <Color x:Key="ProgressBarBg_Light">#15000000</Color>
    <Color x:Key="WordOfDayGradient1_Dark">#2D1B4E</Color>
    <Color x:Key="WordOfDayGradient1_Light">#E8DCF5</Color>
    <Color x:Key="WordOfDayGradient2_Dark">#1E1238</Color>
    <Color x:Key="WordOfDayGradient2_Light">#F0E8F8</Color>
    <Color x:Key="WordOfDayGradient3_Dark">#140E28</Color>
    <Color x:Key="WordOfDayGradient3_Light">#F5F0FA</Color>
    <Color x:Key="ModuleCardBg_Dark">#241840</Color>
    <Color x:Key="ModuleCardBg_Light">#F0ECF5</Color>
    <Color x:Key="GlassBorderStart_Dark">#50FFFFFF</Color>
    <Color x:Key="GlassBorderStart_Light">#30000000</Color>
    <Color x:Key="GlassBorderMid_Dark">#15FFFFFF</Color>
    <Color x:Key="GlassBorderMid_Light">#10000000</Color>
    <Color x:Key="GlassBorderEnd_Dark">#08FFFFFF</Color>
    <Color x:Key="GlassBorderEnd_Light">#05000000</Color>
    <Color x:Key="ShadowColor_Dark">#000000</Color>
    <Color x:Key="ShadowColor_Light">#40000000</Color>
    <Color x:Key="SettingsButtonBg_Dark">#D01A1035</Color>
    <Color x:Key="SettingsButtonBg_Light">#30000000</Color>
    <Color x:Key="AchievementCardBg_Dark">#151025</Color>
    <Color x:Key="AchievementCardBg_Light">#FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>