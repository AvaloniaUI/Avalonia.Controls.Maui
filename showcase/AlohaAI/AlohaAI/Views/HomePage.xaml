<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlohaAI.ViewModels"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="AlohaAI.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False"
             Shell.NavBarVisibilityAnimationEnabled="False"
             BackgroundColor="{AppThemeBinding Dark=#120C24, Light=#F5F3F7}"
             SafeAreaEdges="None">
    <Grid Margin="0,-60,0,0" BackgroundColor="Transparent" SafeAreaEdges="None">
        <BoxView InputTransparent="True">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Dark=#1E1035, Light=#E8E0F2}" Offset="0.0" />
                    <GradientStop Color="{AppThemeBinding Dark=#120C24, Light=#F5F3F7}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>
        <Grid HeightRequest="380" VerticalOptions="Start" InputTransparent="True">
            <Image Source="{AppThemeBinding Dark=bg_sunset.png, Light=bg_sunrise.png}" Aspect="AspectFill" />
            <BoxView>
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Dark=#901E1035, Light=#C0E8E0F2}" Offset="0.5" />
                        <GradientStop Color="{AppThemeBinding Dark=#FF120C24, Light=#FFF5F3F7}" Offset="1.0" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
        </Grid>

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout x:Name="MainContent" Spacing="0" Padding="0,70,0,0" SafeAreaEdges="None">

            <!-- Header: Settings gear (top right) -->
            <Grid Padding="24,0,24,0" ColumnDefinitions="*,Auto" SafeAreaEdges="None">
                <ContentView />
                <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Dark=#D01A1035, Light=#30000000}" StrokeShape="RoundRectangle 14"
                        Stroke="Transparent" WidthRequest="40" HeightRequest="40">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Dark=#000000, Light=#40000000}" Offset="0,2" Radius="8" Opacity="0.3" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToSettingsCommand}" />
                    </Border.GestureRecognizers>
                    <Image Source="icon_settings.png" WidthRequest="22" HeightRequest="22"
                           HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.9" />
                </Border>
            </Grid>

            <!-- AlohaAI Logo -->
            <Image Source="logo_alohaai.png" HeightRequest="40"
                   Aspect="AspectFit" HorizontalOptions="Center"
                   Margin="0,8,0,8" />

            <!-- Welcome text -->
            <Label Text="Aloha! Welcome back!"
                   FontSize="24"
                   FontFamily="OpenSansSemibold"
                   TextColor="{AppThemeBinding Dark=#DDFFFFFF, Light=#DD18132A}"
                   HorizontalTextAlignment="Center"
                   Padding="24,0,24,36">
                <Label.Shadow>
                    <Shadow Brush="#40000000" Offset="0,1" Radius="4" Opacity="0.4" />
                </Label.Shadow>
            </Label>

            <!-- Quick Stats -->
            <Grid Margin="16,0,16,16" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Border StrokeShape="RoundRectangle 16" BackgroundColor="{AppThemeBinding Dark=#181530, Light=#F0ECF5}" Stroke="Transparent" Padding="0">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Dark=#000000, Light=#40000000}" Offset="0,4" Radius="12" Opacity="0.3" />
                    </Border.Shadow>
                    <Grid RowDefinitions="4,*">
                        <BoxView Color="#B8A0E0" HeightRequest="4" VerticalOptions="Start">
                            <BoxView.Clip>
                                <RoundRectangleGeometry CornerRadius="16,16,0,0" Rect="0,0,200,4" />
                            </BoxView.Clip>
                        </BoxView>
                        <VerticalStackLayout Grid.Row="1" Spacing="2" HorizontalOptions="Center" Padding="0,12,0,14">
                            <Label Text="{Binding CurrentStreak}" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Dark=White, Light=#18132A}" HorizontalOptions="Center" />
                            <Label Text="Day Streak" FontSize="11" FontAttributes="Bold" TextColor="#B8A0E0" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" BackgroundColor="{AppThemeBinding Dark=#181530, Light=#F0ECF5}" Stroke="Transparent" Padding="0">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Dark=#000000, Light=#40000000}" Offset="0,4" Radius="12" Opacity="0.3" />
                    </Border.Shadow>
                    <Grid RowDefinitions="4,*">
                        <BoxView Color="#7EB4F0" HeightRequest="4" VerticalOptions="Start">
                            <BoxView.Clip>
                                <RoundRectangleGeometry CornerRadius="16,16,0,0" Rect="0,0,200,4" />
                            </BoxView.Clip>
                        </BoxView>
                        <VerticalStackLayout Grid.Row="1" Spacing="2" HorizontalOptions="Center" Padding="0,12,0,14">
                            <Label Text="{Binding TotalXp}" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Dark=White, Light=#18132A}" HorizontalOptions="Center" />
                            <Label Text="Total XP" FontSize="11" FontAttributes="Bold" TextColor="#7EB4F0" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <Border Grid.Column="2" StrokeShape="RoundRectangle 16" BackgroundColor="{AppThemeBinding Dark=#181530, Light=#F0ECF5}" Stroke="Transparent" Padding="0">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Dark=#000000, Light=#40000000}" Offset="0,4" Radius="12" Opacity="0.3" />
                    </Border.Shadow>
                    <Grid RowDefinitions="4,*">
                        <BoxView Color="#6DD4A0" HeightRequest="4" VerticalOptions="Start">
                            <BoxView.Clip>
                                <RoundRectangleGeometry CornerRadius="16,16,0,0" Rect="0,0,200,4" />
                            </BoxView.Clip>
                        </BoxView>
                        <VerticalStackLayout Grid.Row="1" Spacing="2" HorizontalOptions="Center" Padding="0,12,0,14">
                            <Label Text="{Binding TodayLessons}" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Dark=White, Light=#18132A}" HorizontalOptions="Center" />
                            <Label Text="Today" FontSize="11" FontAttributes="Bold" TextColor="#6DD4A0" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>

            <!-- AI Word of the Day — compact inline definition style -->
            <Border Margin="16,0,16,20" StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.6">
                        <GradientStop Color="{AppThemeBinding Dark=#2D1B4E, Light=#E8DCF5}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Dark=#1E1238, Light=#F0E8F8}" Offset="0.6" />
                        <GradientStop Color="{AppThemeBinding Dark=#140E28, Light=#F5F0FA}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="4,*">
                    <!-- Purple accent stripe -->
                    <BoxView BackgroundColor="#A855F7" VerticalOptions="Fill"
                             InputTransparent="True">
                        <BoxView.Shadow>
                            <Shadow Brush="#A855F7" Offset="3,0" Radius="10" Opacity="0.4" />
                        </BoxView.Shadow>
                    </BoxView>
                    <VerticalStackLayout Grid.Column="1" Spacing="4" Padding="14,12,14,12">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="{Binding WordOfDay}" FontSize="18" FontAttributes="Bold"
                                   TextColor="#D8B4FE" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Word of the Day" FontSize="10"
                                   TextColor="#7C3AED" FontAttributes="Bold" VerticalOptions="Center"
                                   HorizontalOptions="End" />
                        </Grid>
                        <Label Text="{Binding WordDefinition}" FontSize="12.5" TextColor="{AppThemeBinding Dark=#C0B0D8, Light=#6E5A8A}"
                               LineBreakMode="WordWrap" LineHeight="1.25" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Learning Paths Section Header -->
            <Label Text="Learning Paths" FontSize="18" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Dark=#AAAAAA, Light=#6E6580}" Padding="20,0,20,8" />

            <!-- Learning Paths as rich cards (BindableLayout) -->
            <VerticalStackLayout Padding="16,0,16,100" Spacing="14"
                                 BindableLayout.ItemsSource="{Binding PathItems}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:HomePathItem">
                        <Border StrokeShape="RoundRectangle 22" StrokeThickness="1" Padding="0">
                            <Border.BackgroundColor>
                                <AppThemeBinding Dark="#151025" Light="#FFFFFF" />
                            </Border.BackgroundColor>
                            <Border.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{AppThemeBinding Dark=#50FFFFFF, Light=#30000000}" Offset="0.0" />
                                    <GradientStop Color="{AppThemeBinding Dark=#12FFFFFF, Light=#10000000}" Offset="0.5" />
                                    <GradientStop Color="{AppThemeBinding Dark=#06FFFFFF, Light=#05000000}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Stroke>
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Dark=#000000, Light=#40000000}" Offset="0,6" Radius="20" Opacity="0.6" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToPathCommand}"
                                    CommandParameter="{Binding Id}" />
                            </Border.GestureRecognizers>
                            <Grid>
                                <!-- Large semi-transparent icon as background -->
                                <Image Source="{Binding IconImage}" WidthRequest="100" HeightRequest="100"
                                       HorizontalOptions="End" VerticalOptions="Start"
                                       Opacity="0.5" Margin="0,8,8,0" InputTransparent="True" />

                                <!-- Left accent bar -->
                                <BoxView WidthRequest="3" BackgroundColor="{Binding Color}"
                                         HorizontalOptions="Start" VerticalOptions="Fill"
                                         Margin="0,14,0,14" Opacity="0.7"
                                         InputTransparent="True">
                                    <BoxView.Shadow>
                                        <Shadow Brush="{Binding Color}" Offset="2,0" Radius="8" Opacity="0.4" />
                                    </BoxView.Shadow>
                                </BoxView>

                                <!-- Content overlay -->
                                <VerticalStackLayout Spacing="8" Padding="18,14,16,14">
                                    <!-- Row 1: Title -->
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Title}" FontSize="19" FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Dark=White, Light=#18132A}" />
                                        <Label Text="{Binding ProgressText}" FontSize="13"
                                               TextColor="{AppThemeBinding Dark=#AAAAAA, Light=#6E6580}" />
                                    </VerticalStackLayout>

                                    <!-- Row 2: Tags -->
                                    <HorizontalStackLayout Spacing="6">
                                        <Border BackgroundColor="#305B8FD4" StrokeShape="RoundRectangle 10"
                                                Stroke="Transparent" Padding="10,4">
                                            <Label Text="Course" FontSize="10" TextColor="#5B8FD4"
                                                   FontAttributes="Bold" />
                                        </Border>
                                        <Border BackgroundColor="#305B8FD4" StrokeShape="RoundRectangle 10"
                                                Stroke="Transparent" Padding="10,4">
                                            <Label Text="{Binding LevelTag}" FontSize="10" TextColor="#8BB8F4"
                                                   FontAttributes="Bold" />
                                        </Border>
                                    </HorizontalStackLayout>

                                    <!-- Row 3: Progress bar -->
                                    <Grid HeightRequest="5">
                                        <Border BackgroundColor="{AppThemeBinding Dark=#12FFFFFF, Light=#15000000}" StrokeShape="RoundRectangle 2.5"
                                                Stroke="Transparent" />
                                        <Border StrokeShape="RoundRectangle 2.5" Stroke="Transparent"
                                                HorizontalOptions="Start"
                                                BackgroundColor="{Binding Color}"
                                                WidthRequest="{Binding Progress, Converter={StaticResource ProgressToWidthConverter}, ConverterParameter=300}">
                                            <Border.Shadow>
                                                <Shadow Brush="{Binding Color}" Offset="0,0" Radius="6" Opacity="0.6" />
                                            </Border.Shadow>
                                        </Border>
                                    </Grid>

                                    <!-- Row 4: Continue hint -->
                                    <Label Text="{Binding ContinueText}" FontSize="12" TextColor="{AppThemeBinding Dark=#888888, Light=#9A90A8}"
                                           MaxLines="1" LineBreakMode="TailTruncation"
                                           IsVisible="{Binding HasContinueText}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
    </Grid>
</ContentPage>
