<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:MyConference.ViewModels"
             xmlns:models="clr-namespace:MyConference.Models"
             x:Class="MyConference.Views.FavoritesPage"
             x:DataType="viewModels:FavoritesViewModel"
             Title="Favorites">

    <Grid>
        <CollectionView ItemsSource="{Binding FavoriteSessions}">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="32">
                    <Path Data="M12.1,18.55L12,18.65L11.89,18.55C7.14,14.24 4,11.39 4,8.5C4,6.5 5.5,5 7.5,5C9.04,5 10.54,5.99 11.07,7.36H12.93C13.46,5.99 14.96,5 16.5,5C18.5,5 20,6.5 20,8.5C20,11.39 16.86,14.24 12.1,18.55M16.5,3C14.76,3 13.09,3.81 12,5.08C10.91,3.81 9.24,3 7.5,3C4.42,3 2,5.41 2,8.5C2,12.27 5.4,15.36 10.55,20.03L12,21.35L13.45,20.03C18.6,15.36 22,12.27 22,8.5C22,5.41 19.58,3 16.5,3Z"
                          Aspect="Uniform"
                          WidthRequest="64" HeightRequest="64"
                          Fill="{AppThemeBinding Light={StaticResource FavoriteInactiveLight}, Dark={StaticResource FavoriteInactiveDark}}"
                          HorizontalOptions="Center" />
                    <Label Text="No favorites yet"
                           Style="{StaticResource TitleLabel}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Tap the heart on any session to save it here"
                           Style="{StaticResource SubtitleLabel}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Session">
                    <Border Style="{StaticResource CardBorder}" Margin="16,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:FavoritesViewModel}}, Path=NavigateToSessionCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6" Padding="16">
                            <!-- Time, Room, Remove button -->
                            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding TimeSlot}"
                                       Style="{StaticResource TimeLabel}" />
                                <Label Grid.Column="1"
                                       Text="•"
                                       Style="{StaticResource TimeLabel}"
                                       Margin="6,0" />
                                <Label Grid.Column="2"
                                       Text="{Binding RoomName}"
                                       Style="{StaticResource RoomLabel}" />
                                <Button Grid.Column="4"
                                        Text="✕"
                                        FontSize="16"
                                        TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                        BackgroundColor="Transparent"
                                        BorderWidth="0"
                                        Padding="8,4"
                                        WidthRequest="40"
                                        HeightRequest="36"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:FavoritesViewModel}}, Path=RemoveFavoriteCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>

                            <!-- Session title -->
                            <Label Text="{Binding Title}"
                                   Style="{StaticResource CardTitleLabel}" />

                            <!-- Speaker profiles -->
                            <HorizontalStackLayout Spacing="8"
                                                   BindableLayout.ItemsSource="{Binding SpeakerProfiles}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:Speaker">
                                        <HorizontalStackLayout Spacing="6">
                                            <Border StrokeShape="RoundRectangle 12"
                                                    StrokeThickness="0"
                                                    HeightRequest="24"
                                                    WidthRequest="24">
                                                <Image Source="{Binding ProfilePicture}"
                                                       Aspect="AspectFill"
                                                       HeightRequest="24"
                                                       WidthRequest="24" />
                                            </Border>
                                            <Label Text="{Binding FullName}"
                                                   Style="{StaticResource CardSubtitleLabel}"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>

</ContentPage>
