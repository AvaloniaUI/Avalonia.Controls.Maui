<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:MyConference.ViewModels"
             xmlns:models="clr-namespace:MyConference.Models"
             x:Class="MyConference.Views.FavoritesPage"
             x:DataType="viewModels:FavoritesViewModel"
             Title="Favorites">

    <Grid>
        <CollectionView ItemsSource="{Binding FavoriteSessions}">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="32">
                    <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z"
                          Aspect="Uniform"
                          WidthRequest="64" HeightRequest="64"
                          Fill="{AppThemeBinding Light={StaticResource FavoriteInactiveLight}, Dark={StaticResource FavoriteInactiveDark}}"
                          HorizontalOptions="Center" />
                    <Label Text="No favorites yet"
                           Style="{StaticResource TitleLabel}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Tap the heart on any session to save it here"
                           Style="{StaticResource SubtitleLabel}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Session">
                    <Border Style="{StaticResource CardBorder}" Margin="16,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:FavoritesViewModel}}, Path=NavigateToSessionCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6" Padding="16">
                            <!-- Time, Room, Remove button -->
                            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding TimeSlot}"
                                       Style="{StaticResource TimeLabel}" />
                                <Label Grid.Column="1"
                                       Text="•"
                                       Style="{StaticResource TimeLabel}"
                                       Margin="6,0" />
                                <Label Grid.Column="2"
                                       Text="{Binding RoomName}"
                                       Style="{StaticResource RoomLabel}" />
                                <Border Grid.Column="4"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        WidthRequest="40"
                                        HeightRequest="36">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:FavoritesViewModel}}, Path=RemoveFavoriteCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                          Aspect="Uniform"
                                          WidthRequest="16" HeightRequest="16"
                                          Fill="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                          HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>

                            <!-- Session title -->
                            <Label Text="{Binding Title}"
                                   Style="{StaticResource CardTitleLabel}" />

                            <!-- Speaker profiles -->
                            <HorizontalStackLayout Spacing="8"
                                                   BindableLayout.ItemsSource="{Binding SpeakerProfiles}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:Speaker">
                                        <HorizontalStackLayout Spacing="6">
                                            <Border StrokeShape="RoundRectangle 12"
                                                    StrokeThickness="0"
                                                    HeightRequest="24"
                                                    WidthRequest="24">
                                                <Image Source="{Binding ProfilePicture, Converter={StaticResource ProxiedImageConverter}}"
                                                       Aspect="AspectFill"
                                                       HeightRequest="24"
                                                       WidthRequest="24" />
                                            </Border>
                                            <Label Text="{Binding FullName}"
                                                   Style="{StaticResource CardSubtitleLabel}"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>

</ContentPage>
