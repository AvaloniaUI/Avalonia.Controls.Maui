<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:MyConference.ViewModels"
             xmlns:models="clr-namespace:MyConference.Models"
             x:Class="MyConference.Views.SessionsPage"
             x:DataType="viewModels:SessionsViewModel"
             Title="Sessions">

    <Grid>
        <!-- Main content -->
        <RefreshView IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding SessionGroups}"
                            IsGrouped="True"
                            SelectionMode="None">

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="0">
                        <!-- Search bar -->
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                Margin="16,8,16,8"
                                Padding="16,0"
                                HeightRequest="44">
                            <Entry Text="{Binding SearchText}"
                                   Placeholder="Search sessions or speakers..."
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"
                                   FontSize="15"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Fill" />
                        </Border>

                        <!-- Offline banner -->
                        <Border IsVisible="{Binding IsOffline}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource AccentDark}}"
                                Padding="8,4" Margin="0">
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                <Label Text="📡" FontSize="14" VerticalOptions="Center" />
                                <Label Text="Offline mode — showing cached data" FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Day selector chips -->
                        <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never"
                                    IsVisible="{Binding IsMultiDay}">
                            <HorizontalStackLayout Spacing="8"
                                                   Padding="16,4,16,8"
                                                   BindableLayout.ItemsSource="{Binding Days}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border StrokeShape="RoundRectangle 16"
                                                Padding="14,6"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionsViewModel}}, Path=SelectDayCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{Binding}"
                                                   FontSize="13"
                                                   HorizontalTextAlignment="Center"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:TimeSlotGroup">
                        <Grid Padding="20,20,20,8" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="{Binding TimeSlot}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryDark}}"
                                   VerticalOptions="Center" />
                            <BoxView Grid.Column="1" HeightRequest="1"
                                     Color="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}"
                                     VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Session">
                        <Border StrokeShape="RoundRectangle 14"
                                Stroke="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                                StrokeThickness="1"
                                Margin="16,5" Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionsViewModel}}, Path=NavigateToSessionCommand}"
                                    CommandParameter="{Binding}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="0">
                                <!-- Speaker banner -->
                                <Grid BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                      Padding="14,10" ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">
                                    <!-- Speaker avatars -->
                                    <HorizontalStackLayout VerticalOptions="Center"
                                                           BindableLayout.ItemsSource="{Binding SpeakerProfiles}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:Speaker">
                                                <Border StrokeShape="RoundRectangle 20"
                                                        StrokeThickness="2"
                                                        Stroke="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                                        WidthRequest="40" HeightRequest="40"
                                                        Margin="-10,0,0,0">
                                                    <Image Source="{Binding ProfilePicture, Converter={StaticResource ProxiedImageConverter}}"
                                                           Aspect="AspectFill" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>

                                    <!-- Speaker name + tagline -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center" Spacing="1">
                                        <Label Text="{Binding SpeakerNames}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding FirstSpeakerTagLine, FallbackValue=''}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Card content -->
                                <VerticalStackLayout Padding="14,12" Spacing="10">
                                    <!-- Title -->
                                    <Label Text="{Binding Title}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                           LineBreakMode="WordWrap" />

                                    <!-- Chips + Favorite row -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                            <Border StrokeShape="RoundRectangle 5"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryTintLight}, Dark={StaticResource PrimaryTintDark}}"
                                                    Padding="8,4">
                                                <Label Text="{Binding TimeSlot}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={StaticResource PrimaryDarkLight}, Dark={StaticResource PrimaryDarkDark}}"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                            <Border StrokeShape="RoundRectangle 5"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                                    Padding="8,4">
                                                <Label Text="{Binding RoomName}"
                                                       FontSize="11"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                                       VerticalTextAlignment="Center" />
                                            </Border>
                                        </HorizontalStackLayout>

                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                BackgroundColor="Transparent"
                                                Padding="4"
                                                WidthRequest="32" HeightRequest="28"
                                                VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionsViewModel}}, Path=ToggleFavoriteCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Border.GestureRecognizers>
                                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z"
                                                  Aspect="Uniform"
                                                  WidthRequest="18" HeightRequest="18"
                                                  HorizontalOptions="Center" VerticalOptions="Center">
                                                <Path.Triggers>
                                                    <DataTrigger TargetType="Path" Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Fill" Value="{AppThemeBinding Light={StaticResource FavoriteActiveLight}, Dark={StaticResource FavoriteActiveDark}}" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Path" Binding="{Binding IsFavorite}" Value="False">
                                                        <Setter Property="Fill" Value="{AppThemeBinding Light={StaticResource FavoriteInactiveLight}, Dark={StaticResource FavoriteInactiveDark}}" />
                                                    </DataTrigger>
                                                </Path.Triggers>
                                            </Path>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Padding="32">
                        <Label Text="No sessions found"
                               Style="{StaticResource SubtitleLabel}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>
        </RefreshView>

        <!-- Loading indicator -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>

</ContentPage>
