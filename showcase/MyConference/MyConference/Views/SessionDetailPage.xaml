<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:MyConference.ViewModels"
             xmlns:models="clr-namespace:MyConference.Models"
             x:Class="MyConference.Views.SessionDetailPage"
             x:DataType="viewModels:SessionDetailViewModel"
             Title="Session">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,8,0">
            <Label Grid.Column="0"
                   Text="{Binding Session.Title, FallbackValue=''}"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextOnPrimaryLight}, Dark={StaticResource TextOnPrimaryDark}}"
                   LineBreakMode="TailTruncation"
                   VerticalOptions="Center" />
            <Border Grid.Column="2" StrokeShape="RoundRectangle 18"
                    StrokeThickness="0" BackgroundColor="Transparent"
                    WidthRequest="36" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}" />
                </Border.GestureRecognizers>
                <Label Text="♥" FontSize="20"
                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource FavoriteActiveLight}, Dark={StaticResource FavoriteActiveDark}}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsFavorite}" Value="False">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextOnPrimaryLight}, Dark={StaticResource TextOnPrimaryDark}}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
        </Grid>
    </Shell.TitleView>

    <Grid>
        <ScrollView IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Spacing="0" Padding="20,16,20,32">

                <!-- Title -->
                <Label Text="{Binding Session.Title, FallbackValue=''}"
                       FontSize="24" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       Margin="0,0,0,12" />

                <!-- Time & room chips -->
                <HorizontalStackLayout Spacing="10" Margin="0,0,0,20">
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryTintLight}, Dark={StaticResource PrimaryTintDark}}" Padding="10,6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="🕐" FontSize="12" VerticalOptions="Center" />
                            <Label Text="{Binding Session.TimeSlot, FallbackValue=''}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryDarkLight}, Dark={StaticResource PrimaryDarkDark}}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}" Padding="10,6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📍" FontSize="12" VerticalOptions="Center" />
                            <Label Text="{Binding Session.RoomName, FallbackValue=''}"
                                   FontSize="13" TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>

                <!-- Description -->
                <Label Text="About"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,0,0,8" />
                <Label Text="{Binding Session.Description, FallbackValue=''}"
                       FontSize="15" LineHeight="1.6"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       Margin="0,0,0,24" />

                <!-- Divider -->
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" Margin="0,0,0,20" />

                <!-- Speakers section -->
                <Label Text="Speakers"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,0,0,12" />

                <VerticalStackLayout Spacing="12"
                                     BindableLayout.ItemsSource="{Binding Session.SpeakerProfiles, FallbackValue={x:Null}}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Speaker">
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionDetailViewModel}}, Path=NavigateToSpeakerCommand}"
                                        CommandParameter="{Binding}" />
                                </Border.GestureRecognizers>

                                <HorizontalStackLayout Spacing="16">
                                    <!-- Large circular avatar -->
                                    <Border StrokeShape="RoundRectangle 36"
                                            StrokeThickness="0"
                                            WidthRequest="72" HeightRequest="72">
                                        <Image Source="{Binding ProfilePicture}"
                                               Aspect="AspectFill" />
                                    </Border>

                                    <!-- Name + tagline -->
                                    <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding FullName}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                        <Label Text="{Binding TagLine}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>

</ContentPage>
