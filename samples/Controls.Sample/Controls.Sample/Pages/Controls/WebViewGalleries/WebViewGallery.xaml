<views:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Maui.Controls.Sample.Pages.WebViewGalleries.WebViewGallery"
    xmlns:views="clr-namespace:Maui.Controls.Sample.Pages.Base"
    Title="WebView">
    <views:BasePage.Resources>
        <ResourceDictionary>
            <Style x:Key="SectionContainerStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource GalleryItemContainerStyle}">
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <Style x:Key="SectionTitleStyle"
                   TargetType="Label"
                   BasedOn="{StaticResource GalleryItemTitleStyle}">
                <Setter Property="FontSize" Value="Medium" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <Style x:Key="SectionDescriptionStyle"
                   TargetType="Label"
                   BasedOn="{StaticResource GalleryItemDescriptionStyle}">
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>
        </ResourceDictionary>
    </views:BasePage.Resources>
    <views:BasePage.Content>
        <ScrollView>
            <VerticalStackLayout
                Margin="12"
                Spacing="0">
                <Border Style="{StaticResource SectionContainerStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="Inline HTML"
                            Style="{StaticResource SectionTitleStyle}" />
                        <Label
                            Text="Renders a raw HtmlWebViewSource string and lets you replace the content without affecting the other samples."
                            Style="{StaticResource SectionDescriptionStyle}" />
                        <WebView
                            x:Name="HtmlSourceWebView"
                            HeightRequest="160"
                            HorizontalOptions="FillAndExpand">
                            <WebView.Source>
                                <HtmlWebViewSource>
                                    <HtmlWebViewSource.Html>
                                        <![CDATA[
                                        <html>
                                        <head>
                                        </head>
                                        <body>
                                        <h1>.NET MAUI</h1>
                                        <p>This is a local html source.</p>
                                        </body>
                                        </html>
                                        ]]>
                                    </HtmlWebViewSource.Html>
                                </HtmlWebViewSource>
                            </WebView.Source>
                        </WebView>
                        <Button
                            Text="Update Source"
                            Clicked="OnUpdateHtmlSourceClicked" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="Package Assets + User Agent"
                            Style="{StaticResource SectionTitleStyle}" />
                        <Label
                            Text="Loads packaged HTML files into a dedicated WebView so local URLs, relative assets, and custom user agents can be checked in isolation."
                            Style="{StaticResource SectionDescriptionStyle}" />
                        <WebView
                            x:Name="FileWebView"
                            HeightRequest="180"
                            HorizontalOptions="FillAndExpand">
                            <WebView.Source>
                                <HtmlWebViewSource>
                                    <HtmlWebViewSource.Html>
                                        <![CDATA[
                                        <html>
                                        <body>
                                        <h1>.NET MAUI</h1>
                                        <p>Load a packaged html asset such as index.html, useragent.html, or video.html.</p>
                                        </body>
                                        </html>
                                        ]]>
                                    </HtmlWebViewSource.Html>
                                </HtmlWebViewSource>
                            </WebView.Source>
                        </WebView>
                        <Entry
                            x:Name="input"
                            Placeholder="Package asset"
                            Text="index.html" />
                        <Button
                            Text="Load Package Asset"
                            Clicked="OnLoadHtmlFileClicked" />
                        <Entry
                            x:Name="userAgent"
                            Placeholder="Custom user agent"
                            Text="{Binding UserAgent, Source={x:Reference FileWebView}}" />
                        <FlexLayout
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Center">
                            <Button
                                Margin="0,0,12,12"
                                Text="Set User Agent"
                                Clicked="OnSetUserAgentClicked" />
                            <Button
                                Margin="0,0,0,12"
                                Text="Reset User Agent"
                                Clicked="OnResetUserAgentClicked" />
                        </FlexLayout>
                        <Label
                            x:Name="FileStatusLabel"
                            Margin="0"
                            Style="{StaticResource SectionDescriptionStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="Navigation + JavaScript + Video"
                            Style="{StaticResource SectionTitleStyle}" />
                        <Label
                            Text="Keeps history, reload, JavaScript evaluation, and packaged video navigation on a separate WebView so its state stays predictable."
                            Style="{StaticResource SectionDescriptionStyle}" />
                        <WebView
                            x:Name="MauiWebView"
                            Source="https://github.com/dotnet/maui"
                            HeightRequest="220"
                            HorizontalOptions="FillAndExpand" />
                        <FlexLayout
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Center">
                            <Button
                                Margin="0,0,12,12"
                                Text="Go Back"
                                Clicked="OnGoBackClicked" />
                            <Button
                                Margin="0,0,12,12"
                                Text="Go Forward"
                                Clicked="OnGoForwardClicked" />
                            <Button
                                Margin="0,0,12,12"
                                Text="Reload"
                                Clicked="OnReloadClicked" />
                            <Button
                                Margin="0,0,12,12"
                                Text="Eval"
                                Clicked="OnEvalClicked" />
                            <Button
                                Margin="0,0,12,12"
                                Text="Eval Async"
                                Clicked="OnEvalAsyncClicked" />
                            <Button
                                Margin="0,0,0,12"
                                Text="Load HTML5 Video"
                                Clicked="OnLoadHtml5VideoClicked" />
                        </FlexLayout>
                        <Label
                            x:Name="NavigationStatusLabel"
                            Margin="0"
                            Style="{StaticResource SectionDescriptionStyle}" />
                        <Label
                            Text="JavaScript Result"
                            Style="{StaticResource GalleryItemTitleStyle}" />
                        <Label
                            x:Name="EvalResultLabel"
                            Margin="0"
                            Style="{StaticResource SectionDescriptionStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="Cookies"
                            Style="{StaticResource SectionTitleStyle}" />
                        <Label
                            Text="Uses a dedicated WebView with its own CookieContainer. The button seeds MauiCookie and opens httpbin's cookie inspector so the cookie can be verified in-page."
                            Style="{StaticResource SectionDescriptionStyle}" />
                        <WebView
                            x:Name="CookieWebView"
                            HeightRequest="220"
                            HorizontalOptions="FillAndExpand">
                            <WebView.Source>
                                <HtmlWebViewSource>
                                    <HtmlWebViewSource.Html>
                                        <![CDATA[
                                        <html>
                                        <body>
                                        <h1>Cookie Sample</h1>
                                        <p>Press the button below to load httpbin.org and inspect the MauiCookie value.</p>
                                        </body>
                                        </html>
                                        ]]>
                                    </HtmlWebViewSource.Html>
                                </HtmlWebViewSource>
                            </WebView.Source>
                        </WebView>
                        <Button
                            Text="Load httpbin.org with Cookies"
                            Clicked="OnLoadHttpBinClicked" />
                        <Label
                            x:Name="CookieStatusLabel"
                            Margin="0"
                            Style="{StaticResource SectionDescriptionStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="Process Terminated"
                            Style="{StaticResource SectionTitleStyle}" />
                        <Label
                            Text="Shows whether the current Avalonia NativeWebView backend can surface process-failure notifications."
                            Style="{StaticResource SectionDescriptionStyle}" />
                        <Label x:Name="ProcessTerminatedSupportLabel" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    IsVisible="{OnPlatform Android=True, Default=False}"
                    Style="{StaticResource SectionContainerStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label
                            Text="Android Specifics"
                            Style="{StaticResource SectionTitleStyle}" />
                        <Label
                            Text="Toggles Android platform-specific behavior without affecting the other desktop scenarios."
                            Style="{StaticResource SectionDescriptionStyle}" />
                        <FlexLayout
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Center">
                            <Button
                                Margin="0,0,12,12"
                                Text="Allow Mixed Content"
                                Clicked="OnAllowMixedContentClicked" />
                            <Button
                                Margin="0,0,12,12"
                                Text="Enable Zoom Controls"
                                Clicked="OnEnableZoomControlsClicked" />
                            <Button
                                Margin="0,0,0,12"
                                Text="Toggle JavaScript"
                                Clicked="OnJavaScriptEnabledClicked" />
                        </FlexLayout>
                        <Label
                            x:Name="JavaScriptEnabledResult"
                            Margin="0"
                            Style="{StaticResource SectionDescriptionStyle}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.Content>
</views:BasePage>
