<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ControlGallery.Pages"
             x:Class="ControlGallery.Pages.ButtonPage"
             x:DataType="pages:ButtonPage"
             Title="Button">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="20">

            <Label Text="Button Control"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <!-- Basic Buttons -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Basic Buttons"
                           FontAttributes="Bold"/>
                    <Button Text="Default Button"
                            Clicked="OnButtonClicked"/>
                    <Button Text="Disabled Button"
                            IsEnabled="False"/>
                    <Button Text="Button with Long Text That Might Wrap"/>
                    <Label x:Name="ClickCountLabel"
                           Text="Click count: 0"
                           HorizontalOptions="Center"
                           FontAttributes="Italic"/>
                </VerticalStackLayout>
            </Border>

            <!-- Text Colors -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Text Colors"
                           FontAttributes="Bold"/>
                    <Button Text="Red Text"
                            TextColor="Red"/>
                    <Button Text="Green Text"
                            TextColor="Green"/>
                    <Button Text="Blue Text"
                            TextColor="Blue"/>
                    <Button Text="White Text"
                            TextColor="White"
                            BackgroundColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <!-- Background Colors -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Background Colors"
                           FontAttributes="Bold"/>
                    <Button Text="Light Blue"
                            BackgroundColor="LightBlue"/>
                    <Button Text="Light Green"
                            BackgroundColor="LightGreen"/>
                    <Button Text="Light Coral"
                            BackgroundColor="LightCoral"/>
                    <Button Text="Gold"
                            BackgroundColor="Gold"
                            TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <!-- Borders and Strokes -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Borders and Strokes"
                           FontAttributes="Bold"/>
                    <Button Text="Red Border (2px)"
                            BorderColor="Red"
                            BorderWidth="2"/>
                    <Button Text="Blue Border (5px)"
                            BorderColor="Blue"
                            BorderWidth="5"/>
                    <Button Text="Green Dashed Look"
                            BorderColor="Green"
                            BorderWidth="3"
                            BackgroundColor="Transparent"
                            TextColor="Green"/>
                </VerticalStackLayout>
            </Border>

            <!-- Corner Radius -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Corner Radius Variations"
                           FontAttributes="Bold"/>
                    <Button Text="No Radius (0)"
                            BorderColor="Black"
                            BorderWidth="2"
                            BackgroundColor="LightGray"
                            CornerRadius="0"/>
                    <Button Text="Small Radius (5)"
                            BorderColor="Black"
                            BorderWidth="2"
                            BackgroundColor="LightGray"
                            CornerRadius="5"/>
                    <Button Text="Medium Radius (15)"
                            BorderColor="Black"
                            BorderWidth="2"
                            BackgroundColor="LightGray"
                            CornerRadius="15"/>
                    <Button Text="Pill Shape (50)"
                            BorderColor="Black"
                            BorderWidth="2"
                            BackgroundColor="LightGray"
                            CornerRadius="50"
                            HeightRequest="50"/>
                </VerticalStackLayout>
            </Border>

            <!-- Padding -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Padding Variations"
                           FontAttributes="Bold"/>
                    <Button Text="No Padding"
                            Padding="0"
                            BackgroundColor="LightBlue"/>
                    <Button Text="Small Padding (5)"
                            Padding="5"
                            BackgroundColor="LightBlue"/>
                    <Button Text="Medium Padding (15)"
                            Padding="15"
                            BackgroundColor="LightBlue"/>
                    <Button Text="Large Padding (30)"
                            Padding="30"
                            BackgroundColor="LightBlue"/>
                    <Button Text="Asymmetric Padding"
                            Padding="40,10,40,10"
                            BackgroundColor="LightBlue"/>
                </VerticalStackLayout>
            </Border>

            <!-- Character Spacing -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Character Spacing"
                           FontAttributes="Bold"/>
                    <Button Text="Normal Spacing (0)"
                            CharacterSpacing="0"/>
                    <Button Text="Tight Spacing (-1)"
                            CharacterSpacing="-1"/>
                    <Button Text="Loose Spacing (2)"
                            CharacterSpacing="2"/>
                    <Button Text="Very Loose (5)"
                            CharacterSpacing="5"/>
                    <Button Text="UPPERCASE SPACED"
                            CharacterSpacing="3"/>
                </VerticalStackLayout>
            </Border>

            <!-- Font Options -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Font Options"
                           FontAttributes="Bold"/>
                    
                    <!-- FontSize -->
                    <Button Text="Small Font (12)"
                            FontSize="12"/>
                    <Button Text="Default Font (14)"
                            FontSize="14"/>
                    <Button Text="Large Font (20)"
                            FontSize="20"/>
                    <Button Text="Extra Large (28)"
                            FontSize="28"/>
                    
                    <!-- FontAttributes -->
                    <Button Text="Normal Font"
                            FontAttributes="None"/>
                    <Button Text="Bold Font"
                            FontAttributes="Bold"/>
                    <Button Text="Italic Font"
                            FontAttributes="Italic"/>
                    <Button Text="Bold Italic Font"
                            FontAttributes="Bold,Italic"/>
                    
                    <!-- FontFamily -->
                    <Button Text="Default Font Family"/>
                    <Button Text="Courier New"
                            FontFamily="Courier New"/>
                    <Button Text="Georgia"
                            FontFamily="Georgia"/>
                </VerticalStackLayout>
            </Border>

            <!-- TextTransform -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Text Transform"
                           FontAttributes="Bold"/>
                    <Button Text="Default Transform"
                            TextTransform="Default"/>
                    <Button Text="uppercase text"
                            TextTransform="Uppercase"/>
                    <Button Text="LOWERCASE TEXT"
                            TextTransform="Lowercase"/>
                    <Button Text="None Transform"
                            TextTransform="None"/>
                </VerticalStackLayout>
            </Border>

            <!-- Command and CommandParameter -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Command and CommandParameter"
                           FontAttributes="Bold"/>
                    <Button Text="Execute Command"
                            Command="{Binding MyCommand}"/>
                    <Button Text="Command with Parameter (Action1)"
                            Command="{Binding ParameterizedCommand}"
                            CommandParameter="Action1"/>
                    <Button Text="Command with Parameter (Action2)"
                            Command="{Binding ParameterizedCommand}"
                            CommandParameter="Action2"/>
                    <Button Text="Command with Parameter (Delete)"
                            Command="{Binding ParameterizedCommand}"
                            CommandParameter="Delete"
                            BackgroundColor="Red"
                            TextColor="White"/>
                    <Button Text="Disabled Command"
                            Command="{Binding DisabledCommand}"/>
                    <Label x:Name="CommandResultLabel"
                           Text="No command executed yet"
                           HorizontalOptions="Center"
                           FontAttributes="Italic"/>
                </VerticalStackLayout>
            </Border>

            <!-- Pressed and Released Events -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Pressed and Released Events"
                           FontAttributes="Bold"/>
                    <Label Text="Press and hold to see state changes:"
                           FontSize="12"
                           FontAttributes="Italic"/>
                    
                    <Button Text="Press Me"
                            BackgroundColor="LightBlue"
                            TextColor="Black"
                            Pressed="OnButton1Pressed"
                            Released="OnButton1Released"/>
                    
                    <Button Text="Interactive Button"
                            BackgroundColor="Green"
                            TextColor="White"
                            BorderColor="DarkGreen"
                            BorderWidth="2"
                            Pressed="OnButton2Pressed"
                            Released="OnButton2Released"/>
                    
                    <Button Text="Animated Press"
                            BackgroundColor="Purple"
                            TextColor="White"
                            Pressed="OnButton3Pressed"
                            Released="OnButton3Released"/>
                </VerticalStackLayout>
            </Border>

            <!-- Styled Buttons -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Styled Button Examples"
                           FontAttributes="Bold"/>
                    
                    <!-- Primary Button -->
                    <Button Text="Primary Button"
                            TextColor="White"
                            BackgroundColor="DarkBlue"
                            Padding="20,10"
                            CornerRadius="8"
                            BorderColor="Navy"
                            BorderWidth="2"
                            CharacterSpacing="1"/>
                    
                    <!-- Secondary Button -->
                    <Button Text="Secondary Button"
                            TextColor="DarkBlue"
                            BackgroundColor="White"
                            Padding="20,10"
                            CornerRadius="8"
                            BorderColor="DarkBlue"
                            BorderWidth="2"/>
                    
                    <!-- Success Button -->
                    <Button Text="Success"
                            TextColor="White"
                            BackgroundColor="Green"
                            Padding="20,10"
                            CornerRadius="6"/>
                    
                    <!-- Danger Button -->
                    <Button Text="Danger"
                            TextColor="White"
                            BackgroundColor="Red"
                            Padding="20,10"
                            CornerRadius="6"/>
                    
                    <!-- Warning Button -->
                    <Button Text="Warning"
                            TextColor="Black"
                            BackgroundColor="Gold"
                            Padding="20,10"
                            CornerRadius="6"/>
                    
                    <!-- Info Button -->
                    <Button Text="Info"
                            TextColor="White"
                            BackgroundColor="CornflowerBlue"
                            Padding="20,10"
                            CornerRadius="6"/>
                    
                    <!-- Ghost Button -->
                    <Button Text="Ghost Button"
                            TextColor="DarkSlateGray"
                            BackgroundColor="Transparent"
                            Padding="20,10"
                            BorderColor="DarkSlateGray"
                            BorderWidth="1"
                            CornerRadius="6"/>
                </VerticalStackLayout>
            </Border>

            <!-- Button Layouts -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Button Layouts"
                           FontAttributes="Bold"/>
                    
                    <Label Text="Horizontal Button Group:"
                           FontSize="12"/>
                    <HorizontalStackLayout Spacing="10"
                                           HorizontalOptions="Center">
                        <Button Text="Option A"
                                WidthRequest="100"/>
                        <Button Text="Option B"
                                WidthRequest="100"/>
                        <Button Text="Option C"
                                WidthRequest="100"/>
                    </HorizontalStackLayout>
                    
                    <Label Text="Full Width Button:"
                           FontSize="12"/>
                    <Button Text="Full Width Button"
                            HorizontalOptions="Fill"/>
                    
                    <Label Text="Centered Button:"
                           FontSize="12"/>
                    <Button Text="Centered"
                            HorizontalOptions="Center"
                            WidthRequest="200"/>
                    
                    <Label Text="Small Buttons:"
                           FontSize="12"/>
                    <HorizontalStackLayout Spacing="5"
                                           HorizontalOptions="Center">
                        <Button Text="Yes"
                                WidthRequest="80"
                                HeightRequest="30"
                                Padding="5"/>
                        <Button Text="No"
                                WidthRequest="80"
                                HeightRequest="30"
                                Padding="5"/>
                        <Button Text="Cancel"
                                WidthRequest="80"
                                HeightRequest="30"
                                Padding="5"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
            
            <!-- Content Layout -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Content Layout"
                           FontAttributes="Bold"/>
                    <Label Text="Adjust icon position and spacing using ContentLayout."/>

                    <Button Text="Image Left (12 spacing)"
                            ImageSource="dotnet_bot.png"
                            ContentLayout="Left,12"
                            Padding="16,10"
                            BackgroundColor="White"
                            BorderColor="Gray"
                            BorderWidth="1"
                            TextColor="Black"/>

                    <Button Text="Image Right (10 spacing)"
                            ImageSource="dotnet_bot.png"
                            ContentLayout="Right,10"
                            Padding="16,10"
                            BackgroundColor="White"
                            BorderColor="Gray"
                            BorderWidth="1"
                            TextColor="Black"/>

                    <Button Text="Image Top (8 spacing)"
                            ImageSource="dotnet_bot.png"
                            ContentLayout="Top,8"
                            Padding="16,12"
                            BackgroundColor="White"
                            BorderColor="Gray"
                            BorderWidth="1"
                            TextColor="Black"/>

                    <Button Text="Image Bottom (10 spacing)"
                            ImageSource="dotnet_bot.png"
                            ContentLayout="Bottom,10"
                            Padding="16,14"
                            BackgroundColor="White"
                            BorderColor="Gray"
                            BorderWidth="1"
                            TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <!-- ImageButton Section -->
            <Label Text="ImageButton Control"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0"/>

            <!-- Basic ImageButtons -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Basic ImageButtons"
                           FontAttributes="Bold"/>
                    <ImageButton Source="dotnet_bot.png"
                                 WidthRequest="100"
                                 HeightRequest="100"
                                 Clicked="OnImageButtonClicked"
                                 HorizontalOptions="Center"/>
                    <ImageButton Source="dotnet_bot.png"
                                 WidthRequest="80"
                                 HeightRequest="80"
                                 IsEnabled="False"
                                 HorizontalOptions="Center"/>
                    <Label Text="Disabled ImageButton above"
                           FontSize="12"
                           FontAttributes="Italic"
                           HorizontalOptions="Center"/>
                    <Label x:Name="ImageButtonClickCountLabel"
                           Text="ImageButton click count: 0"
                           HorizontalOptions="Center"
                           FontAttributes="Italic"/>
                </VerticalStackLayout>
            </Border>

            <!-- ImageButton Aspect Modes -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Aspect Modes"
                           FontAttributes="Bold"/>
                    <Label Text="Each ImageButton is 120x80 to show aspect differences:"
                           FontSize="12"/>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="120"
                                         HeightRequest="80"
                                         Aspect="AspectFit"
                                         BackgroundColor="LightGray"/>
                            <Label Text="AspectFit"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="120"
                                         HeightRequest="80"
                                         Aspect="AspectFill"
                                         BackgroundColor="LightGray"/>
                            <Label Text="AspectFill"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="120"
                                         HeightRequest="80"
                                         Aspect="Fill"
                                         BackgroundColor="LightGray"/>
                            <Label Text="Fill"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="120"
                                         HeightRequest="80"
                                         Aspect="Center"
                                         BackgroundColor="LightGray"/>
                            <Label Text="Center"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ImageButton Borders and CornerRadius -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Borders and Corner Radius"
                           FontAttributes="Bold"/>

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="80"
                                         HeightRequest="80"
                                         BorderColor="Red"
                                         BorderWidth="3"
                                         CornerRadius="0"/>
                            <Label Text="Square"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="80"
                                         HeightRequest="80"
                                         BorderColor="Blue"
                                         BorderWidth="3"
                                         CornerRadius="10"/>
                            <Label Text="Rounded"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="80"
                                         HeightRequest="80"
                                         BorderColor="Green"
                                         BorderWidth="3"
                                         CornerRadius="40"/>
                            <Label Text="Circle"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Label Text="Border Width Variations:"
                           FontSize="12"
                           Margin="0,10,0,0"/>
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="60"
                                     HeightRequest="60"
                                     BorderColor="Purple"
                                     BorderWidth="1"/>
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="60"
                                     HeightRequest="60"
                                     BorderColor="Purple"
                                     BorderWidth="3"/>
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="60"
                                     HeightRequest="60"
                                     BorderColor="Purple"
                                     BorderWidth="5"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ImageButton Padding -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Padding"
                           FontAttributes="Bold"/>
                    <Label Text="Each button has the same image but different padding:"
                           FontSize="12"/>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="80"
                                         HeightRequest="80"
                                         Padding="0"
                                         BackgroundColor="LightBlue"
                                         BorderColor="DarkBlue"
                                         BorderWidth="1"/>
                            <Label Text="Padding=0"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="80"
                                         HeightRequest="80"
                                         Padding="10"
                                         BackgroundColor="LightBlue"
                                         BorderColor="DarkBlue"
                                         BorderWidth="1"/>
                            <Label Text="Padding=10"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="80"
                                         HeightRequest="80"
                                         Padding="20"
                                         BackgroundColor="LightBlue"
                                         BorderColor="DarkBlue"
                                         BorderWidth="1"/>
                            <Label Text="Padding=20"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ImageButton Background Colors -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Background Colors"
                           FontAttributes="Bold"/>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="70"
                                     HeightRequest="70"
                                     BackgroundColor="LightCoral"
                                     Padding="5"
                                     CornerRadius="8"/>
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="70"
                                     HeightRequest="70"
                                     BackgroundColor="LightGreen"
                                     Padding="5"
                                     CornerRadius="8"/>
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="70"
                                     HeightRequest="70"
                                     BackgroundColor="LightBlue"
                                     Padding="5"
                                     CornerRadius="8"/>
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="70"
                                     HeightRequest="70"
                                     BackgroundColor="Gold"
                                     Padding="5"
                                     CornerRadius="8"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ImageButton Command and CommandParameter -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Command and CommandParameter"
                           FontAttributes="Bold"/>

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="70"
                                         HeightRequest="70"
                                         Command="{Binding ImageButtonCommand}"
                                         BackgroundColor="LightGray"
                                         CornerRadius="10"/>
                            <Label Text="Simple Command"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="70"
                                         HeightRequest="70"
                                         Command="{Binding ImageButtonParameterizedCommand}"
                                         CommandParameter="Image1"
                                         BackgroundColor="LightGreen"
                                         CornerRadius="10"/>
                            <Label Text="Param: Image1"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="70"
                                         HeightRequest="70"
                                         Command="{Binding ImageButtonParameterizedCommand}"
                                         CommandParameter="Image2"
                                         BackgroundColor="LightBlue"
                                         CornerRadius="10"/>
                            <Label Text="Param: Image2"
                                   FontSize="10"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Label x:Name="ImageButtonCommandResultLabel"
                           Text="No ImageButton command executed yet"
                           HorizontalOptions="Center"
                           FontAttributes="Italic"/>
                </VerticalStackLayout>
            </Border>

            <!-- ImageButton Pressed and Released Events -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Pressed and Released Events"
                           FontAttributes="Bold"/>
                    <Label Text="Press and hold to see visual feedback:"
                           FontSize="12"
                           FontAttributes="Italic"/>

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="80"
                                     HeightRequest="80"
                                     BackgroundColor="LightBlue"
                                     CornerRadius="10"
                                     BorderColor="DarkBlue"
                                     BorderWidth="2"
                                     Pressed="OnImageButton1Pressed"
                                     Released="OnImageButton1Released"/>

                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="80"
                                     HeightRequest="80"
                                     BackgroundColor="LightGreen"
                                     CornerRadius="40"
                                     BorderColor="DarkGreen"
                                     BorderWidth="2"
                                     Pressed="OnImageButton2Pressed"
                                     Released="OnImageButton2Released"/>

                        <ImageButton Source="dotnet_bot.png"
                                     WidthRequest="80"
                                     HeightRequest="80"
                                     BackgroundColor="LightCoral"
                                     CornerRadius="10"
                                     BorderColor="DarkRed"
                                     BorderWidth="2"
                                     Pressed="OnImageButton3Pressed"
                                     Released="OnImageButton3Released"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Styled ImageButtons -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Styled ImageButton Examples"
                           FontAttributes="Bold"/>

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <!-- Social Media Style -->
                        <VerticalStackLayout>
                            <ImageButton Source="dotnet_bot.png"
                                         WidthRequest="50"
                                         HeightRequest="50"
                                         BackgroundColor="#1DA1F2"
                                         CornerRadius="25"
                                         Padding="10"/>
                            <Label Text="Social"
