<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlGallery.Pages.ShellSamples.ShellPlayground.ShellCommonDetailPage"
             Title="Shell Detail Page">
    <VerticalStackLayout Padding="30" Spacing="20" HorizontalOptions="Center" VerticalOptions="Center">
        <Label x:Name="TitleLabel" Text="Detail Page" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        <Label x:Name="ParameterLabel" Text="No parameters" HorizontalOptions="Center" />
        <Button Text="Go Back" Clicked="OnGoBack" WidthRequest="200" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
