<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlGallery.Pages.Essentials.BatteryPage"
             Title="Battery Info">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Battery Info"
                   Style="{StaticResource SubHeadline}"/>

            <!-- Battery Level and State -->
            <Border Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Battery Level and State"
                           FontAttributes="Bold"/>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                        <Label Text="Charge Level:" Grid.Row="0" Grid.Column="0" FontAttributes="Bold"/>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                            <Label x:Name="LevelLabel"/>
                            <ProgressBar x:Name="LevelProgressBar" Progress="0" HeightRequest="8"/>
                        </VerticalStackLayout>

                        <Label Text="State:" Grid.Row="1" Grid.Column="0" FontAttributes="Bold"/>
                        <Label x:Name="StateLabel" Grid.Row="1" Grid.Column="1"/>

                        <Label Text="Power Source:" Grid.Row="2" Grid.Column="0" FontAttributes="Bold"/>
                        <Label x:Name="PowerSourceLabel" Grid.Row="2" Grid.Column="1"/>

                        <Label Text="Energy Saver:" Grid.Row="3" Grid.Column="0" FontAttributes="Bold"/>
                        <Label x:Name="EnergySaverLabel" Grid.Row="3" Grid.Column="1"/>
                    </Grid>

                    <Button Text="Refresh Info" Clicked="OnRefreshClicked" HorizontalOptions="Center" WidthRequest="200"/>
                </VerticalStackLayout>
            </Border>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
