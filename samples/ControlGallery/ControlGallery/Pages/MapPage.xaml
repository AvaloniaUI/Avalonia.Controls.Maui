<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Avalonia.Controls.Maui.Maps.Controls;assembly=Avalonia.Controls.Maui.Maps"
             xmlns:pages="clr-namespace:ControlGallery.Pages"
             x:Class="ControlGallery.Pages.MapPage"
             Title="Map">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="24">

            <Label Text="Map Control"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            
            <!-- Basic Map -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Basic Map"
                           FontAttributes="Bold" />
                    <Label Text="A simple map displaying OpenStreetMap tiles."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <maps:MapView x:Name="BasicMap"
                               HeightRequest="300"
                               WidthRequest="350"
                               CenterLatitude="37.3891"
                               CenterLongitude="-5.9845"
                               ZoomLevel="12"
                               HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Map Type -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Map Type"
                           FontAttributes="Bold" />
                    <Label Text="Switch between different map styles (Street, Satellite, Hybrid)."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <maps:MapView x:Name="MapTypeMap"
                               HeightRequest="300"
                               CenterLatitude="37.3891"
                               CenterLongitude="-5.9845"
                               ZoomLevel="12" />
                    <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                         <Label Text="Type:" VerticalOptions="Center" />
                         <Picker x:Name="MapTypePicker" 
                                 SelectedIndexChanged="OnMapTypeChanged"
                                 WidthRequest="150">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Street</x:String>
                                    <x:String>Satellite</x:String>
                                    <x:String>Hybrid</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                            <Picker.SelectedIndex>0</Picker.SelectedIndex>
                        </Picker>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- User Position -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="User Location"
                           FontAttributes="Bold" />
                    <Label Text="Automatically shows your current location with a custom indicator."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <maps:MapView x:Name="UserLocationMap"
                               HeightRequest="300"
                               CenterLatitude="59.4370"
                               CenterLongitude="24.7536"
                               ZoomLevel="10" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Map Clicked"
                           FontAttributes="Bold" />
                    <Label Text="Click on the map to see coordinates."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <Label x:Name="ClickedCoordsLabel"
                           Text="Click anywhere on the map..."
                           FontSize="14"
                           FontAttributes="Italic"
                           TextColor="#2196F3"
                           Margin="0,0,0,8" />
                    <maps:MapView x:Name="ClickableMap"
                               HeightRequest="250"
                               CenterLatitude="37.3891"
                               CenterLongitude="-5.9845"
                               ZoomLevel="12" />
                </VerticalStackLayout>
            </Border>
            
            <!-- Map Selection (Pins & Shapes) -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Pin and Shape Selection"
                           FontAttributes="Bold" />
                    <Label Text="Click on pins or shapes to see their details in a popup."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <Label x:Name="SelectionInfoLabel"
                           Text="Click on a pin or shape..."
                           FontSize="14"
                           FontAttributes="Italic"
                           TextColor="#4CAF50"
                           Margin="0,0,0,8" />
                    <maps:MapView x:Name="SelectionMap"
                               HeightRequest="300"
                               CenterLatitude="37.3891"
                               CenterLongitude="-5.9845"
                               ZoomLevel="12"
                               MapClicked="OnSelectionMapClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Pins -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Pins"
                           FontAttributes="Bold" />
                    <Label Text="Add and remove pins on the map."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <Label x:Name="PinsCountLabel"
                           Text="Pins: 0"
                           FontSize="14"
                           TextColor="#4CAF50"
                           Margin="0,0,0,8" />
                    <maps:MapView x:Name="PinsMap"
                               HeightRequest="300"
                               CenterLatitude="47.0"
                               CenterLongitude="10.0"
                               ZoomLevel="4" />
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Start">
                        <Button Text="Add Rome" Clicked="OnAddRomePinClicked" Margin="0,0,8,8" />
                        <Button Text="Add Paris" Clicked="OnAddParisPinClicked" Margin="0,0,8,8" />
                        <Button Text="Add Berlin" Clicked="OnAddBerlinPinClicked" Margin="0,0,8,8" />
                        <Button Text="Clear All" Clicked="OnClearPinsClicked" Margin="0,0,8,8" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ItemsSource & ItemTemplate -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="ItemsSource Binding"
                           FontAttributes="Bold" />
                    <Label Text="Bind a collection of custom data objects to the map pins."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    
                    <maps:MapView x:Name="ItemsSourceMap"
                               HeightRequest="300"
                               CenterLatitude="40.4168"
                               CenterLongitude="-3.7038"
                               ZoomLevel="5"
                               ItemsSource="{Binding PlaceData}">
                        <maps:MapView.ItemTemplate>
                            <DataTemplate x:DataType="pages:PlaceItem">
                                <maps:MapPin Label="{Binding Name}"
                                             Location="{Binding Position}"
                                             Address="{Binding Description}"
                                             Icon="{Binding Icon}"
                                             IconScale="{Binding IconScale}"
                                             Type="Place" />
                            </DataTemplate>
                        </maps:MapView.ItemTemplate>
                    </maps:MapView>
                    
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Start">
                        <Button Text="Add Madrid" Clicked="OnAddMadridDataClicked" Margin="0,0,8,8" />
                        <Button Text="Add Barcelona" Clicked="OnAddBarcelonaDataClicked" Margin="0,0,8,8" />
                        <Button Text="Clear Data" Clicked="OnClearDataClicked" Margin="0,0,8,8" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Scroll and Zoom Control -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Scroll and Zoom Control"
                           FontAttributes="Bold" />
                    <Label Text="Showing Sevilla, Spain. Enable or disable map interactions."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <maps:MapView x:Name="InteractionMap"
                               HeightRequest="250"
                               CenterLatitude="37.3891"
                               CenterLongitude="-5.9845"
                               ZoomLevel="12" />
                    <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                        <Label Text="Zoom:" VerticalOptions="Center" />
                        <Slider x:Name="ZoomSlider"
                                Minimum="1"
                                Maximum="18"
                                Value="12"
                                WidthRequest="200"
                                ValueChanged="OnZoomSliderChanged" />
                        <Label x:Name="ZoomLevelLabel" 
                               Text="12" 
                               WidthRequest="30"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="12">
                        <HorizontalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="Scroll Enabled:" VerticalOptions="Center" />
                            <Switch x:Name="ScrollSwitch" 
                                    IsToggled="True"
                                    Toggled="OnScrollSwitchToggled" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                            <Label Text="Zoom Enabled:" VerticalOptions="Center" />
                            <Switch x:Name="ZoomSwitch" 
                                    IsToggled="True"
                                    Toggled="OnZoomSwitchToggled" />
                        </HorizontalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Shapes (Polygons, Polylines, Circles) -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Shapes"
                           FontAttributes="Bold" />
                    <Label Text="Draw polygons, polylines, and circles on the map."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <Label x:Name="ShapesCountLabel"
                           Text="Shapes: 0"
                           FontSize="14"
                           TextColor="#FF5722"
                           Margin="0,0,0,8" />
                    <maps:MapView x:Name="ShapesMap"
                               HeightRequest="300"
                               CenterLatitude="46.0"
                               CenterLongitude="8.0"
                               ZoomLevel="4" />
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Start">
                        <Button Text="Add Polygon" Clicked="OnAddPolygonClicked" Margin="0,0,8,8" />
                        <Button Text="Add Polyline" Clicked="OnAddPolylineClicked" Margin="0,0,8,8" />
                        <Button Text="Add Circle" Clicked="OnAddCircleClicked" Margin="0,0,8,8" />
                        <Button Text="Clear Shapes" Clicked="OnClearShapesClicked" Margin="0,0,8,8" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>



            <!-- Move to Region -->
            <Border Stroke="Gray"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Move to Region"
                           FontAttributes="Bold" />
                    <Label Text="Navigate to specific locations on the map."
                           FontSize="12"
                           TextColor="Gray"
                           Margin="0,0,0,4" />
                    <Label x:Name="CurrentLocationLabel"
                           Text="Current: New York, USA"
                           FontSize="14"
                           FontAttributes="Italic"
                           TextColor="#4CAF50"
                           Margin="0,0,0,8" />
                    <maps:MapView x:Name="RegionMap"
                               HeightRequest="300"
                               CenterLatitude="40.7128"
                               CenterLongitude="-74.0060"
                               ZoomLevel="12" />
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Start">
                        <Button Text="New York" Clicked="OnMoveToNYCClicked" Margin="0,0,8,8" />
                        <Button Text="London" Clicked="OnMoveToLondonClicked" Margin="0,0,8,8" />
                        <Button Text="Tokyo" Clicked="OnMoveToTokyoClicked" Margin="0,0,8,8" />
                        <Button Text="Sydney" Clicked="OnMoveToSydneyClicked" Margin="0,0,8,8" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>


            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
