<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlGallery.Pages.WebViewPage"
             Title="WebView">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="20">

            <!-- Load Web -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Load Web"
                           FontAttributes="Bold" />
                    <Label Text="Loads remote web content into a dedicated WebView."
                           FontSize="12"
                           TextColor="Gray" />

                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                AlignItems="Center"
                                JustifyContent="Start">
                        <Button Text="Avalonia"
                                Margin="0,0,10,10"
                                Clicked="OnLoadWebAvaloniaClicked" />
                        <Button Text="MAUI"
                                Margin="0,0,0,10"
                                Clicked="OnLoadWebMauiClicked" />
                    </FlexLayout>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Entry x:Name="WebUrlEntry"
                               Grid.Column="0"
                               Placeholder="Enter remote URL..."
                               Text="https://avaloniaui.net"
                               ReturnType="Go"
                               Completed="OnWebUrlEntryCompleted" />
                        <Button Text="Go"
                                Grid.Column="1"
                                Clicked="OnLoadWebGoClicked" />
                    </Grid>

                    <Border Stroke="#CFCFCF"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <WebView x:Name="LoadWebWebView"
                                 HeightRequest="220"
                                 Source="https://avaloniaui.net"
                                 Navigated="OnLoadWebWebViewNavigated" />
                    </Border>

                    <Label x:Name="LoadWebStatusLabel"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- Load Local -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Load Local"
                           FontAttributes="Bold" />
                    <Label Text="Loads packaged HTML from app assets and resolves relative files such as stylesheets."
                           FontSize="12"
                           TextColor="Gray" />

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Entry x:Name="LocalAssetEntry"
                               Grid.Column="0"
                               Placeholder="Enter packaged asset path..."
                               Text="WebView/index.html"
                               ReturnType="Go"
                               Completed="OnLocalAssetEntryCompleted" />
                        <Button Text="Load Asset"
                                Grid.Column="1"
                                Clicked="OnLoadLocalAssetClicked" />
                    </Grid>

                    <Border Stroke="#CFCFCF"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <WebView x:Name="LocalPreviewWebView"
                                 HeightRequest="220"
                                 Source="WebView/index.html"
                                 Navigated="OnLocalPreviewNavigated" />
                    </Border>

                    <Label x:Name="LocalPreviewStatusLabel"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- Inline HTML -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Inline HTML"
                           FontAttributes="Bold" />
                    <Label Text="Renders HtmlWebViewSource content directly so markup updates can be verified without touching navigation history."
                           FontSize="12"
                           TextColor="Gray" />

                    <Button Text="Refresh Inline Content"
                            HorizontalOptions="Start"
                            Clicked="OnRefreshInlineHtmlClicked" />

                    <Border Stroke="#CFCFCF"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <WebView x:Name="InlineHtmlWebView"
                                 HeightRequest="220" />
                    </Border>

                    <Label x:Name="InlineHtmlStatusLabel"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- Navigation -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Navigation"
                           FontAttributes="Bold" />
                    <Label Text="Exercises back, forward, and reload using a WebView with its own navigation history, including same-document history changes from site menus."
                           FontSize="12"
                           TextColor="Gray" />

                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                AlignItems="Center"
                                JustifyContent="Start">
                        <Button Text="Open Avalonia"
                                Margin="0,0,10,10"
                                Clicked="OnNavigationAvaloniaClicked" />
                        <Button Text="Open Local"
                                Margin="0,0,10,10"
                                Clicked="OnNavigationLocalClicked" />
                        <Button x:Name="NavigationBackButton"
                                Text="Back"
                                Margin="0,0,10,10"
                                IsEnabled="{Binding Source={x:Reference NavigationWebView}, Path=CanGoBack}"
                                Clicked="OnNavigationBackClicked" />
                        <Button x:Name="NavigationForwardButton"
                                Text="Forward"
                                Margin="0,0,10,10"
                                IsEnabled="{Binding Source={x:Reference NavigationWebView}, Path=CanGoForward}"
                                Clicked="OnNavigationForwardClicked" />
                        <Button Text="Reload"
                                Margin="0,0,0,10"
                                Clicked="OnNavigationReloadClicked" />
                    </FlexLayout>

                    <Border Stroke="#CFCFCF"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <WebView x:Name="NavigationWebView"
                                 HeightRequest="220"
                                 Source="https://avaloniaui.net"
                                 Navigated="OnNavigationWebViewNavigated" />
                    </Border>

                    <Label x:Name="NavigationStatusLabel"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- Events -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Events"
                           FontAttributes="Bold" />
                    <Label Text="Captures Navigating and Navigated events in order on a dedicated WebView."
                           FontSize="12"
                           TextColor="Gray" />

                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                AlignItems="Center"
                                JustifyContent="Start">
                        <Button Text="Load Avalonia"
                                Margin="0,0,10,10"
                                Clicked="OnEventsAvaloniaClicked" />
                        <Button Text="Load Local"
                                Margin="0,0,10,10"
                                Clicked="OnEventsLocalClicked" />
                        <Button Text="Reload"
                                Margin="0,0,10,10"
                                Clicked="OnEventsReloadClicked" />
                        <Button Text="Clear Log"
                                Margin="0,0,0,10"
                                Clicked="OnClearEventsLogClicked" />
                    </FlexLayout>

                    <Border Stroke="#CFCFCF"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <WebView x:Name="EventsWebView"
                                 HeightRequest="200"
                                 Source="https://avaloniaui.net"
                                 Navigating="OnEventsWebViewNavigating"
                                 Navigated="OnEventsWebViewNavigated" />
                    </Border>

                    <Label x:Name="EventsStatusLabel"
                           FontSize="12"
                           TextColor="Gray" />

                    <Editor x:Name="EventsLogEditor"
                            HeightRequest="120"
                            IsReadOnly="True"
                            AutoSize="TextChanges"
                            BackgroundColor="#F7F7F7"
                            FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- Cookies Management -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Cookies"
                           FontAttributes="Bold" />
                    <Label Text="Seeds MauiCookie into a dedicated CookieContainer and loads httpbin's /cookies echo endpoint so the response proves what the server received."
                           FontSize="12"
                           TextColor="Gray" />

                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                AlignItems="Center"
                                JustifyContent="Start">
                        <Button Text="Verify Cookie"
                                Margin="0,0,10,10"
                                Clicked="OnLoadCookieSampleClicked" />
                        <Button Text="Reset Cookie View"
                                Margin="0,0,0,10"
                                Clicked="OnResetCookieSampleClicked" />
                    </FlexLayout>

                    <Border Stroke="#CFCFCF"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <WebView x:Name="CookieWebView"
                                 HeightRequest="240"
                                 Navigated="OnCookieWebViewNavigated">
                            <WebView.Source>
                                <HtmlWebViewSource>
                                    <HtmlWebViewSource.Html>
                                        <![CDATA[
                                        <!DOCTYPE html>
                                        <html lang="en">
                                        <body style="font-family: Segoe UI, sans-serif; margin: 24px;">
                                            <h1>Cookie sample</h1>
                                            <p>Press <strong>Verify Cookie</strong> to open <code>https://httpbin.org/cookies</code>.</p>
                                            <p>Success means the page shows <code>"MauiCookie": "Hmmm Cookies!"</code>.</p>
                                        </body>
                                        </html>
                                        ]]>
                                    </HtmlWebViewSource.Html>
                                </HtmlWebViewSource>
                            </WebView.Source>
                        </WebView>
                    </Border>

                    <Label x:Name="CookieStatusLabel"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- Playground -->
            <Border Stroke="Gray"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Playground"
                           FontAttributes="Bold" />
                    <Label Text="A larger freeform WebView for trying remote URLs or packaged assets after the focused samples above."
                           FontSize="12"
                           TextColor="Gray" />

                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                AlignItems="Center"
                                JustifyContent="Start">
                        <Button x:Name="PlaygroundBackButton"
                                Text="Back"
                                Margin="0,0,10,10"
                                IsEnabled="{Binding Source={x:Reference PlaygroundWebView}, Path=CanGoBack}"
                                Clicked="OnPlaygroundBackClicked" />
                        <Button x:Name="PlaygroundForwardButton"
                                Text="Forward"
                                Margin="0,0,10,10"
                                IsEnabled="{Binding Source={x:Reference PlaygroundWebView}, Path=CanGoForward}"
                                Clicked="OnPlaygroundForwardClicked" />
                        <Button Text="Reload"
                                Margin="0,0,10,10"
                                Clicked="OnPlaygroundReloadClicked" />
                        <Button Text="Avalonia"
                                Margin="0,0,10,10"
                                Clicked="OnPlaygroundAvaloniaClicked" />
                        <Button Text="MAUI"
                                Margin="0,0,10,10"
                                Clicked="OnPlaygroundMauiClicked" />
                        <Button Text="Local Asset"
                                Margin="0,0,0,10"
                                Clicked="OnPlaygroundLocalClicked" />
                    </FlexLayout>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Entry x:Name="PlaygroundUrlEntry"
                               Grid.Column="0"
                               Placeholder="Enter URL or packaged asset path..."
                               Text="https://avaloniaui.net"
                               ReturnType="Go"
                               Completed="OnPlaygroundUrlEntryCompleted" />
                        <Button Text="Go"
                                Grid.Column="1"
                                Clicked="OnPlaygroundGoClicked" />
                    </Grid>

                    <Border Stroke="#CFCFCF"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <WebView x:Name="PlaygroundWebView"
                                 HeightRequest="360"
                                 Source="https://avaloniaui.net"
                                 Navigated="OnPlaygroundWebViewNavigated" />
                    </Border>

                    <Label x:Name="PlaygroundStatusLabel"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
