<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlGallery.Pages.WebViewPage"
             Title="WebView">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- Navigation Bar -->
        <Border Padding="8" Grid.Row="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,10,10"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
                <Button x:Name="BackButton"
                        Text="&#x25C0;"
                        Grid.Column="0"
                        IsEnabled="False"
                        WidthRequest="40"
                        Clicked="OnBackClicked"/>
                <Button x:Name="ForwardButton"
                        Text="&#x25B6;"
                        Grid.Column="1"
                        IsEnabled="False"
                        WidthRequest="40"
                        Clicked="OnForwardClicked"/>
                <Button Text="&#x21BB;"
                        Grid.Column="2"
                        WidthRequest="40"
                        Clicked="OnReloadClicked"/>
                <Entry x:Name="UrlEntry"
                       Grid.Column="3"
                       Placeholder="Enter URL..."
                       Text="https://avaloniaui.net"
                       ReturnType="Go"
                       Completed="OnUrlEntryCompleted"/>
                <Button Text="Go"
                        Grid.Column="4"
                        Clicked="OnGoClicked"/>
            </Grid>
        </Border>

        <!-- WebView -->
        <WebView x:Name="MainWebView"
                 Grid.Row="1"
                 Source="https://avaloniaui.net"
                 Navigating="OnWebViewNavigating"
                 Navigated="OnWebViewNavigated"/>

    </Grid>
</ContentPage>
