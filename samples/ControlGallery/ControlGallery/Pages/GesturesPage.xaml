<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlGallery.Pages.GesturesPage"
             Title="Gestures">
    <ContentPage.Resources>
        <Color x:Key="SectionBorderLight">#CCCCCC</Color>
        <Color x:Key="SectionBorderDark">#444444</Color>
        <Color x:Key="SectionBackgroundLight">#FFFFFF</Color>
        <Color x:Key="SectionBackgroundDark">#1E1E1E</Color>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            

            <!-- Single Tap -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Single Tap" FontAttributes="Bold"/>
                    <Label Text="TapGestureRecognizer with NumberOfTapsRequired=&quot;1&quot;" FontSize="12" FontAttributes="Italic"/>

                    <Border x:Name="SingleTapBox" 
                            HeightRequest="150" 
                            StrokeThickness="1"
                            Stroke="Gray"
                            BackgroundColor="LightBlue">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSingleTapTapped" NumberOfTapsRequired="1" />
                        </Border.GestureRecognizers>
                        <Label x:Name="SingleTapLabel" 
                               Text="Tap me!" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               FontAttributes="Bold"/>
                    </Border>
                    <Label x:Name="SingleTapCountLabel" Text="Taps: 0" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Double Tap -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Double Tap" FontAttributes="Bold"/>
                    <Label Text="TapGestureRecognizer with NumberOfTapsRequired=&quot;2&quot;" FontSize="12" FontAttributes="Italic"/>

                    <Border x:Name="DoubleTapBox" 
                            HeightRequest="150" 
                            StrokeThickness="1"
                            Stroke="Gray"
                            BackgroundColor="LightCoral">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDoubleTapTapped" NumberOfTapsRequired="2" />
                        </Border.GestureRecognizers>
                        <Label x:Name="DoubleTapLabel" 
                               Text="Double tap me!" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               FontAttributes="Bold"/>
                    </Border>
                    <Label x:Name="DoubleTapCountLabel" Text="Double Taps: 0" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Pan Gesture -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Pan Gesture" FontAttributes="Bold"/>
                    <Label Text="PanGestureRecognizer - drag the box around" FontSize="12" FontAttributes="Italic"/>

                    <Border HeightRequest="200" 
                            StrokeThickness="1"
                            Stroke="Gray"
                            BackgroundColor="#F0F0F0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <AbsoluteLayout>
                            <Border x:Name="PanBox" 
                                    HeightRequest="60" 
                                    WidthRequest="60"
                                    StrokeThickness="0"
                                    BackgroundColor="MediumPurple"
                                    AbsoluteLayout.LayoutBounds="0.5,0.5,60,60"
                                    AbsoluteLayout.LayoutFlags="PositionProportional">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <PanGestureRecognizer PanUpdated="OnPanUpdated" />
                                </Border.GestureRecognizers>
                                <Label Text="Drag me" 
                                       FontSize="10"
                                       TextColor="White"
                                       VerticalOptions="Center" 
                                       HorizontalOptions="Center"/>
                            </Border>
                        </AbsoluteLayout>
                    </Border>
                    <Label x:Name="PanStatusLabel" Text="Pan: Idle" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Pointer Gesture -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Pointer Gesture" FontAttributes="Bold"/>
                    <Label Text="PointerGestureRecognizer - Hover, Press, Move" FontSize="12" FontAttributes="Italic"/>

                    <Border x:Name="PointerBox" 
                            HeightRequest="150" 
                            StrokeThickness="1"
                            Stroke="Gray"
                            BackgroundColor="LightGoldenrodYellow">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnPointerEntered"
                                                      PointerExited="OnPointerExited"
                                                      PointerMoved="OnPointerMoved"
                                                      PointerPressed="OnPointerPressed"
                                                      PointerReleased="OnPointerReleased"/>
                        </Border.GestureRecognizers>
                        <Label x:Name="PointerLabel" 
                               Text="Hover/Click me!" 
                               TextColor="Black"
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               FontAttributes="Bold"/>
                    </Border>
                    <Label x:Name="PointerStatusLabel" Text="Status: Idle" HorizontalOptions="Center" />
                    <Label x:Name="PointerPositionLabel" Text="Position: -" HorizontalOptions="Center" FontSize="12" />
                </VerticalStackLayout>
            </Border>
            
            <!-- Swipe Gesture -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Swipe Gesture" FontAttributes="Bold"/>
                    <Label Text="SwipeGestureRecognizer (Left, Right, Up, Down)" FontSize="12" FontAttributes="Italic"/>

                    <Border x:Name="SwipeBox" 
                            HeightRequest="150" 
                            StrokeThickness="1"
                            Stroke="Gray"
                            BackgroundColor="LightCyan">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <SwipeGestureRecognizer Direction="Left" Swiped="OnSwiped" />
                            <SwipeGestureRecognizer Direction="Right" Swiped="OnSwiped" />
                            <SwipeGestureRecognizer Direction="Up" Swiped="OnSwiped" />
                            <SwipeGestureRecognizer Direction="Down" Swiped="OnSwiped" />
                        </Border.GestureRecognizers>
                        <Label x:Name="SwipeLabel" 
                               Text="Swipe me!" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               TextColor="Black"
                               FontAttributes="Bold"/>
                    </Border>
                    <Label x:Name="SwipeStatusLabel" Text="Last Swipe: None" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Grid Tap Gesture -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Grid Tap Gesture" FontAttributes="Bold"/>
                    <Label Text="TapGestureRecognizer on a Grid layout" FontSize="12" FontAttributes="Italic"/>

                    <Grid x:Name="TapGrid"
                          HeightRequest="150"
                          BackgroundColor="LightSteelBlue"
                          ColumnDefinitions="*,*"
                          Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGridTapTapped" NumberOfTapsRequired="1" />
                        </Grid.GestureRecognizers>
                        <Label Text="Left"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"/>
                        <Label Text="Right"
                               Grid.Column="1"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"/>
                    </Grid>
                    <Label x:Name="GridTapCountLabel" Text="Grid Taps: 0" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Grid Pointer Gesture -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Grid Pointer Gesture" FontAttributes="Bold"/>
                    <Label Text="PointerGestureRecognizer on a Grid with multiple cells" FontSize="12" FontAttributes="Italic"/>

                    <Grid x:Name="PointerGrid"
                          HeightRequest="150"
                          BackgroundColor="Lavender"
                          RowDefinitions="*,*"
                          ColumnDefinitions="*,*"
                          RowSpacing="2"
                          ColumnSpacing="2">
                        <Grid.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnGridPointerEntered"
                                                      PointerExited="OnGridPointerExited"
                                                      PointerMoved="OnGridPointerMoved" />
                        </Grid.GestureRecognizers>
                        <BoxView Color="CornflowerBlue" Grid.Row="0" Grid.Column="0" />
                        <BoxView Color="MediumSeaGreen" Grid.Row="0" Grid.Column="1" />
                        <BoxView Color="Coral" Grid.Row="1" Grid.Column="0" />
                        <BoxView Color="MediumPurple" Grid.Row="1" Grid.Column="1" />
                    </Grid>
                    <Label x:Name="GridPointerStatusLabel" Text="Grid Pointer: Idle" HorizontalOptions="Center" />
                    <Label x:Name="GridPointerPositionLabel" Text="Position: -" HorizontalOptions="Center" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- Grid Multiple Gestures -->
            <Border Stroke="{AppThemeBinding Light={StaticResource SectionBorderLight}, Dark={StaticResource SectionBorderDark}}"
                    Background="{AppThemeBinding Light={StaticResource SectionBackgroundLight}, Dark={StaticResource SectionBackgroundDark}}"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Grid Multiple Gestures" FontAttributes="Bold"/>
                    <Label Text="Tap + Pointer + Swipe on the same Grid" FontSize="12" FontAttributes="Italic"/>

                    <Grid x:Name="MultiGestureGrid"
                          HeightRequest="150"
                          BackgroundColor="MistyRose"
                          Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMultiGridTapped" NumberOfTapsRequired="1" />
                            <PointerGestureRecognizer PointerEntered="OnMultiGridPointerEntered"
                                                      PointerExited="OnMultiGridPointerExited" />
                            <SwipeGestureRecognizer Direction="Left" Swiped="OnMultiGridSwiped" />
                            <SwipeGestureRecognizer Direction="Right" Swiped="OnMultiGridSwiped" />
                        </Grid.GestureRecognizers>
                        <Label x:Name="MultiGestureGridLabel"
                               Text="Tap, hover, or swipe!"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"/>
                    </Grid>
                    <Label x:Name="MultiGestureStatusLabel" Text="Last Event: None" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
