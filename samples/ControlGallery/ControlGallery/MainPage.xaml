<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			xmlns:local="clr-namespace:ControlGallery"
			x:DataType="local:MainPage"
			FlyoutLayoutBehavior="Split"
			x:Class="ControlGallery.MainPage">
	<FlyoutPage.Flyout>
		<ContentPage
			BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
			x:Name="FlyoutPageMenu"
			Title="Control Gallery">
			<Grid RowDefinitions="Auto,*">
				<SearchBar Placeholder="Search..."
						   TextChanged="OnSearchBarTextChanged"
						   BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
						   Margin="6"/>

				<CollectionView Grid.Row="1"
					x:Name="MenuCollectionView"
					ItemsSource="{Binding FilteredSamples}"
					IsGrouped="True"
					SelectionMode="Single"
					SelectionChanged="OnSelectionChanged"
					BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">

					<CollectionView.GroupHeaderTemplate>
						<DataTemplate x:DataType="local:SampleGroup">
							<Label Text="{Binding Name}"
								   FontAttributes="Bold"
								   FontSize="16"
								   Padding="10,8"
								   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
								   BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}"/>
						</DataTemplate>
					</CollectionView.GroupHeaderTemplate>

					<CollectionView.ItemTemplate>
						<DataTemplate x:DataType="local:SampleItem">
							<VerticalStackLayout Padding="15,8">
								<Label Text="{Binding Title}"
									   FontSize="14"
									   TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
								<Label Text="{Binding Detail}"
									   FontSize="12"
									   TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}"/>
							</VerticalStackLayout>
						</DataTemplate>
					</CollectionView.ItemTemplate>

				</CollectionView>
			</Grid>
		</ContentPage>
	</FlyoutPage.Flyout>
	<FlyoutPage.Detail>
		<ContentPage>
		</ContentPage>
	</FlyoutPage.Detail>
</FlyoutPage>
